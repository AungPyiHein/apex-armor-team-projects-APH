@page "/customers/add"
@using MiniPos.Frontend.Shared.Types
@inject NotificationService Notification

<PageTitle>Add Customer - MiniPOS</PageTitle>

<div class="animate-slide-down max-w-2xl mx-auto pb-12">
    <!-- Header with Back Navigation -->
    <div class="mb-8">
        <button
            class="btn btn-outline border-border/50 bg-white hover:bg-slate-50 px-5 flex items-center gap-2 group transition-all"
            @onclick="GoBack">
            <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
            <span class="font-bold text-xs uppercase tracking-tight">Back to Customers</span>
        </button>
        <h1 class="text-3xl font-black tracking-tight text-foreground mt-4">Add New Customer</h1>
        <p class="text-muted-foreground mt-1 text-sm">Expand your directory by registering a new client profile.</p>
    </div>

    <!-- Form Card -->
    <div class="pos-card p-8 bg-white/60 shadow-xl border-border/40 relative overflow-hidden">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-2xl"></div>

        <EditForm Model="@_customerRequest" OnValidSubmit="HandleSubmit" class="space-y-6 relative z-10">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 gap-5">
                <!-- Associated Merchant -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Merchant Owner</label>
                    <div class="relative flex items-center">
                        <i data-lucide="building" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <select @bind="_customerRequest.MerchantId" class="w-full pl-11 pr-10 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm appearance-none cursor-pointer">
                            <option value="">Choose a Merchant...</option>
                            @if (_merchants != null)
                            {
                                @foreach (var m in _merchants)
                                {
                                    <option value="@m.Id.ToString()">@m.Name</option>
                                }
                            }
                        </select>
                        <i data-lucide="chevron-down" class="absolute right-4 w-4 h-4 text-muted-foreground pointer-events-none"></i>
                    </div>
                    @if (_customerRequest.MerchantId == Guid.Empty && _hasSubmittedAttempt)
                    {
                        <div class="text-xs text-destructive font-semibold mt-1">Merchant is required.</div>
                    }
                </div>

                <!-- Customer Name -->
                <div class="space-y-1">
                    <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Full Name</label>
                    <div class="relative flex items-center">
                        <i data-lucide="user" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                        <InputText @bind-Value="_customerRequest.Name" placeholder="e.g. John Doe" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                    </div>
                    <ValidationMessage For="@(() => _customerRequest.Name)" class="text-xs text-destructive font-semibold mt-1" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <!-- Phone Number -->
                    <div class="space-y-1">
                        <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Phone Number</label>
                        <div class="relative flex items-center">
                            <i data-lucide="phone" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                            <InputText @bind-Value="_customerRequest.PhoneNumber" placeholder="+123456789" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                        </div>
                        <ValidationMessage For="@(() => _customerRequest.PhoneNumber)" class="text-xs text-destructive font-semibold mt-1" />
                    </div>

                    <!-- Email Address -->
                    <div class="space-y-1">
                        <label class="text-[11px] font-black uppercase tracking-widest text-muted-foreground">Email Address</label>
                        <div class="relative flex items-center">
                            <i data-lucide="mail" class="absolute left-4 w-4 h-4 text-muted-foreground"></i>
                            <InputText @bind-Value="_customerRequest.Email" placeholder="john@example.com" class="w-full pl-11 pr-4 py-3 bg-white border border-border/60 rounded-xl text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary/40 focus:outline-none font-medium shadow-sm" />
                        </div>
                        <ValidationMessage For="@(() => _customerRequest.Email)" class="text-xs text-destructive font-semibold mt-1" />
                    </div>
                </div>
            </div>

            <div class="pt-4 flex items-center gap-4">
                <button type="submit"
                        class="btn btn-primary px-8 h-12 shadow-xl shadow-primary/30 flex items-center gap-3 transition-all active:scale-95"
                        disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <div class="animate-spin rounded-full h-5 w-5 border-4 border-t-white border-white/20"></div>
                    }
                    else
                    {
                        <i data-lucide="check-circle" class="w-5 h-5 font-black"></i>
                    }
                    <span class="font-black uppercase tracking-tight text-sm">Register Customer</span>
                </button>
                <button type="button" class="btn btn-ghost rounded-xl px-6 py-3 font-bold text-sm" @onclick="GoBack" disabled="@_isSubmitting">Cancel</button>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private CustomerFormModel _customerRequest = new();
    private List<MerchantDto>? _merchants;
    
    private bool _isSubmitting = false;
    private bool _hasSubmittedAttempt = false;

    public class CustomerFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Too long.")]
        public string Name { get; set; } = "";

        public string? PhoneNumber { get; set; }

        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address.")]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Merchant is required.")]
        public Guid MerchantId { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync($"api/merchants");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult<MerchantDto>>();
                if (result is { Data: not null })
                {
                    _merchants = result.Data;
                    if (_merchants.Any())
                    {
                        _customerRequest.MerchantId = _merchants[0].Id;
                    }
                }
            }
            else
            {
                await Notification.ShowError("Failed to load merchants.");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Error loading merchants: {ex.Message}");
        }
    }

    private void GoBack() { Navigation.NavigateTo("/customers"); }

    private async Task HandleSubmit()
    {
        _hasSubmittedAttempt = true;
        if (_customerRequest.MerchantId == Guid.Empty) return;
        
        _isSubmitting = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/customers", new CustomerCreateRequest
            {
                MerchantId = _customerRequest.MerchantId,
                Name = _customerRequest.Name,
                PhoneNumber = _customerRequest.PhoneNumber,
                Email = _customerRequest.Email
            });

            if (response.IsSuccessStatusCode)
            {
                await Notification.ShowSuccess("Customer registered successfully!");
                Navigation.NavigateTo("/customers");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await Notification.ShowError($"Registration failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Network error: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { await JSRuntime.InvokeVoidAsync("initIcons"); }
    }
}
