            </div>

            <!-- Right Column: Stats & Meta -->
            <div class="flex flex-col gap-8">
                <!-- Customer Stats -->
                <div class="pos-card bg-white/60 backdrop-blur-xl shadow-xl border-white/60 p-6 flex flex-col gap-6 relative overflow-hidden">
                    <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-primary/5 rounded-full blur-2xl"></div>
                    
                    <h3 class="text-sm font-black uppercase tracking-wider text-muted-foreground relative z-10">Engagement Metrics</h3>
                    
                    <div class="grid grid-cols-1 gap-4 relative z-10">
                        <div class="bg-primary/5 rounded-2xl p-4 border border-primary/10">
                            <p class="text-[10px] font-black uppercase tracking-widest text-primary/60 mb-1">Lifetime Value</p>
                            <p class="text-2xl font-black text-primary font-outfit">@(_customer.Orders?.Sum(o => o.TotalAmount).ToString("N0") ?? "0") <span class="text-xs opacity-60">MMK</span></p>
                        </div>
                        
                        <div class="bg-slate-50/80 rounded-2xl p-4 border border-border/40">
                            <p class="text-[10px] font-black uppercase tracking-widest text-muted-foreground mb-1">Average Order</p>
                            <p class="text-xl font-black text-foreground font-outfit">@((_customer.Orders?.Any() == true ? _customer.Orders.Average(o => o.TotalAmount) : 0).ToString("N0")) <span class="text-xs opacity-60 text-muted-foreground">MMK</span></p>
                        </div>
                    </div>

                    <div class="space-y-4 pt-2 relative z-10">
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-muted-foreground font-bold italic">Member Since</span>
                            <span class="font-black text-foreground">@_customer.CreatedAt.ToString("MMM yyyy")</span>
                        </div>
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-muted-foreground font-bold italic">Last Purchase</span>
                            <span class="font-black text-foreground">@(_customer.Orders?.OrderByDescending(o => o.CreatedAt).FirstOrDefault()?.CreatedAt.ToString("MMM dd, yyyy") ?? "Never")</span>
                        </div>
                    </div>
                </div>
                
                <!-- Loyalty Status -->
                <div class="pos-card bg-gradient-to-br from-primary/10 to-primary/5 backdrop-blur-xl shadow-xl border-white/40 p-6 flex flex-col items-center text-center relative group">
                    <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center text-primary shadow-lg mb-4 group-hover:scale-110 transition-transform">
                        <i data-lucide="award" class="w-8 h-8"></i>
                    </div>
                    @if (_customer.Royalty == null)
                    {
                        <h4 class="text-lg font-black text-foreground">No Loyalty Data</h4>
                        <p class="text-xs text-muted-foreground mt-1 font-medium">Loyalty / royalty information isn’t available for this customer yet.</p>
                        <div class="w-full mt-6 rounded-xl border border-white/50 bg-white/50 px-4 py-3 text-left">
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-muted-foreground font-bold italic">Current Points</span>
                                <span class="font-black text-foreground">0</span>
                            </div>
                            <div class="flex justify-between items-center text-xs mt-2">
