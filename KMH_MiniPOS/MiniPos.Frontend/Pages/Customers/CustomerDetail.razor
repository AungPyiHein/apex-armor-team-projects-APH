                                        <i data-lucide="phone" class="w-4 h-4"></i>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-black uppercase tracking-tighter text-muted-foreground">Phone Number</p>
                                        <p class="text-sm font-bold text-foreground">@(string.IsNullOrEmpty(_customer.PhoneNumber) ? "Not provided" : _customer.PhoneNumber)</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 group/item">
                                    <div class="w-8 h-8 rounded-lg bg-white/80 border border-border/40 flex items-center justify-center text-muted-foreground group-hover/item:text-primary transition-colors shadow-sm">
