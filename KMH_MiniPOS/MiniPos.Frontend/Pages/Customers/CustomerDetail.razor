            <span class="font-bold text-xs uppercase tracking-tight">Back to Directory</span>
        </button>
        <div class="flex items-center gap-2">
            <button class="btn btn-primary btn-sm rounded-lg flex items-center gap-1.5 active:scale-95 shadow-lg shadow-primary/20" @onclick="() => _showEditModal = true">
                <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Edit Profile
            </button>
            <button class="btn btn-outline border-destructive/30 text-destructive btn-sm rounded-lg flex items-center gap-1.5 hover:bg-destructive/5 active:scale-95" @onclick="() => _showDeleteModal = true">
                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Delete
            </button>
        </div>
    </div>

    @if (_customer == null)
