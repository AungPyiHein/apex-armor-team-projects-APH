                        </div>
                        <h3 class="text-xl font-black tracking-tight">Edit Profile</h3>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="space-y-1">
                            <label class="text-[10px] font-black text-muted-foreground uppercase tracking-widest">Full Name</label>
                            <input type="text" @bind="_editName" class="w-full px-5 py-3 bg-white border border-border/60 rounded-2xl text-sm focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:outline-none font-bold shadow-sm" />
                        </div>
                        <div class="grid grid-cols-1 gap-4">
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-muted-foreground uppercase tracking-widest">Phone Number</label>
                                <input type="text" @bind="_editPhone" class="w-full px-5 py-3 bg-white border border-border/60 rounded-2xl text-sm focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:outline-none font-bold shadow-sm" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-[10px] font-black text-muted-foreground uppercase tracking-widest">Email Address</label>
                                <input type="email" @bind="_editEmail" class="w-full px-5 py-3 bg-white border border-border/60 rounded-2xl text-sm focus:ring-4 focus:ring-primary/10 focus:border-primary/40 focus:outline-none font-bold shadow-sm" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex flex-col gap-3 pt-4">
                        <button class="btn btn-primary rounded-2xl h-12 text-sm shadow-xl shadow-primary/30 flex items-center justify-center gap-2" @onclick="HandleEdit" disabled="@_isSubmitting">
                            @if (_isSubmitting) { <div class="animate-spin rounded-full h-4 w-4 border-2 border-white/20 border-t-white"></div> }
                            <span class="font-black uppercase tracking-tight">Save Changes</span>
                        </button>
                        <button class="btn btn-ghost rounded-2xl h-12 text-sm font-bold text-muted-foreground" @onclick='() => _showEditModal = false' disabled="@_isSubmitting">Cancel</button>
                    </div>
                </div>
            </div>
        }

        <!-- Delete Modal -->
        @if (_showDeleteModal)
        {
            <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[100] flex items-center justify-center p-4 animate-fade-in">
                <div class="bg-white/95 backdrop-blur-2xl rounded-[2rem] shadow-2xl border border-white/60 w-full max-w-md p-8 animate-scale-up space-y-6">
                    <div class="flex items-center gap-3 text-destructive">
                        <div class="w-10 h-10 rounded-xl bg-destructive/10 flex items-center justify-center border border-destructive/20">
                            <i data-lucide="trash-2" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-xl font-black tracking-tight text-foreground">Remove Customer?</h3>
                    </div>
                    
                    <div class="p-4 bg-destructive/5 rounded-2xl border border-destructive/10">
                        <p class="text-sm text-destructive font-medium leading-relaxed">
                            Are you sure you want to remove <b>@_customer.Name</b> from your directory? 
                            This action will soft-delete the record and they will no longer appear in active lists.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 pt-2">
                        <button class="btn btn-destructive rounded-2xl h-12 text-sm shadow-xl shadow-destructive/20 flex items-center justify-center gap-2" @onclick="HandleDelete" disabled="@_isSubmitting">
                            @if (_isSubmitting) { <div class="animate-spin rounded-full h-4 w-4 border-2 border-white/20 border-t-white"></div> }
                            <span class="font-black uppercase tracking-tight">Yes, Delete Record</span>
                        </button>
                        <button class="btn btn-ghost rounded-2xl h-12 text-sm font-bold text-muted-foreground" @onclick='() => _showDeleteModal = false' disabled="@_isSubmitting">Cancel</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string CustomerId { get; set; } = "";

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private CustomerDetails? _customer;

    // Modals controls
    private bool _showEditModal = false;
    private bool _showDeleteModal = false;

    private string _editName = "";
    private string _editPhone = "";
    private string _editEmail = "";

    private bool _isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomer();
    }

    private async Task LoadCustomer()
    {
        try
        {
            var response = await Http.GetAsync($"api/customers/{CustomerId}");
            if (!response.IsSuccessStatusCode)
            {
                await Notification.ShowError("Failed to load customer profile.");
                return;
            }

            _customer = await response.Content.ReadFromJsonAsync<CustomerDetails>();
            if (_customer != null)
            {
                _editName = _customer.Name;
                _editPhone = _customer.PhoneNumber ?? "";
                _editEmail = _customer.Email ?? "";
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Error loading customer: {ex.Message}");
        }
    }

    private void GoBack() { Navigation.NavigateTo("/customers"); }
    private void NavToOrder(Guid id) { Navigation.NavigateTo($"/sales/{id}"); }

    private async Task HandleEdit()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            await Notification.ShowError("Name is required.");
            return;
        }
        
        _isSubmitting = true;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/customers/{CustomerId}", new CustomerUpdateRequest
            {
                Name = _editName,
                PhoneNumber = _editPhone,
                Email = _editEmail
            });

            if (response.IsSuccessStatusCode)
            {
                await Notification.ShowSuccess("Profile updated successfully!");
                _showEditModal = false;
                await LoadCustomer();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await Notification.ShowError($"Update failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Network error: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task HandleDelete()
    {
        _isSubmitting = true;
        try
        {
            var response = await Http.DeleteAsync($"api/customers/{CustomerId}");
            if (response.IsSuccessStatusCode)
            {
                await Notification.ShowSuccess("Customer record removed.");
                Navigation.NavigateTo("/customers");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await Notification.ShowError($"Delete failed: {error}");
            }
        }
        catch (Exception ex)
        {
            await Notification.ShowError($"Network error: {ex.Message}");
        }
        finally
        {
            _isSubmitting = false;
            _showDeleteModal = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _customer != null) 
        { 
            await JSRuntime.InvokeVoidAsync("initIcons"); 
        }
    }
}
