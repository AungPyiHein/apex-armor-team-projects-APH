                                <span class="font-black text-foreground">0</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <h4 class="text-lg font-black text-foreground">@(_customer.Royalty.Tier)</h4>
                        <p class="text-xs text-muted-foreground mt-1 font-medium">Loyalty status based on points activity.</p>

                        <div class="w-full mt-6 rounded-xl border border-white/50 bg-white/50 px-4 py-3 text-left">
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-muted-foreground font-bold italic">Current Points</span>
                                <span class="font-black text-foreground">@_customer.Royalty.CurrentPoint.ToString("N0")</span>
                            </div>
                            <div class="flex justify-between items-center text-xs mt-2">
                                <span class="text-muted-foreground font-bold italic">Lifetime Points</span>
                                <span class="font-black text-foreground">@_customer.Royalty.LifetimePoints.ToString("N0")</span>
                            </div>
