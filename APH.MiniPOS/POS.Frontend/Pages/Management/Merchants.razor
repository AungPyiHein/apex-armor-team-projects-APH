@page "/merchants"
@attribute [Authorize(Roles = "Admin")]
@layout MainLayout
@using POS.Frontend.Models.Merchants
@inject IMerchantService MerchantService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Merchants</h2>
            <p class="page-subtitle">Super Admin view of all businesses</p>
        </div>
        <button class="btn-primary" @onclick="ShowAddModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Register Merchant
        </button>
    </div>

    @if (IsLoading && !IsSearching)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @ErrorMessage
        </div>
    }
    <div class="card">
        <div class="card-header shrink-0">
            <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between w-full">
                <div class="flex gap-3 flex-wrap items-center">
                    <div class="relative">
                        <input type="text" placeholder="Search merchants…" class="form-input max-w-xs pl-9" 
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        @if (IsSearching)
                        {
                            <div class="absolute right-3 top-2.5 w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                        }
                    </div>
                </div>

                <!-- View Toggle -->
                <div class="flex bg-gray-100 dark:bg-gray-800 p-1 rounded-lg shrink-0">
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(!isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = false">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
                        List
                    </button>
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = true">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                        Grid
                    </button>
                </div>
            </div>
        </div>

        <div class="flex-1 overflow-y-auto px-4 sm:px-6 py-4">
        @if (!isGridView)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Merchant Name</th>
                        <th>Contact Email</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!MerchantList.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10 text-muted italic">No merchants found</td>
                        </tr>
                    }
                    @foreach (var m in MerchantList)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-lg bg-gray-100 dark:bg-border/30 flex items-center justify-center shrink-0">
                                        <span class="text-gray-700 dark:text-gray-300 font-bold text-xs">@m.Name[0]</span>
                                    </div>
                                    <span class="font-medium text-gray-800 dark:text-gray-200">@m.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">
                                @m.ContactEmail
                                @if (!string.IsNullOrEmpty(m.PhoneNumber))
                                {
                                    <div class="text-xs italic mt-0.5 opacity-70">@m.PhoneNumber</div>
                                }
                            </td>
                            <td>
                                @if (m.IsActive)
                                { <span class="badge badge-success">Active</span> }
                                else
                                { <span class="badge badge-warning">Suspended</span> }
                            </td>
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => ShowEditModal(m)">Edit</button>
                                    <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => ShowDeleteConfirm(m.Id, m.Name)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                @foreach (var m in MerchantList)
                {
                    <div class="group bg-white dark:bg-surface border border-gray-100 dark:border-gray-800 rounded-2xl p-4 hover:shadow-xl hover:border-accent/20 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
                                <span class="font-bold">@m.Name[0]</span>
                            </div>
                            @if (m.IsActive)
                            { <span class="badge badge-success">Active</span> }
                            else
                            { <span class="badge badge-warning">Suspended</span> }
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-1 truncate">@m.Name</h4>
                            <p class="text-sm text-gray-400 mb-1 truncate">@m.ContactEmail</p>
                            @if (!string.IsNullOrEmpty(m.PhoneNumber))
                            {
                                <p class="text-xs text-gray-500 mb-2 truncate">📞 @m.PhoneNumber</p>
                            }
                        </div>
                        <div class="flex gap-2 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
                            <button class="btn-secondary flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowEditModal(m)">Edit</button>
                            <button class="btn-danger flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowDeleteConfirm(m.Id, m.Name)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
        
        @if (!IsLoading && TotalRecords > 0)
        {
            <div class="mt-6 border-t border-gray-100 dark:border-gray-800 pt-6">
                <Pagination CurrentPage="CurrentPage" 
                            TotalPages="TotalPages" 
                            TotalRecords="TotalRecords" 
                            PageSize="PageSize" 
                            OnPageChanged="HandlePageChanged" />
            </div>
        }
    </div>
</div>

@if (ShowModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">@(IsEditMode ? "Edit Merchant" : "Register New Merchant")</h3>
                <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Merchant Name</label>
                    <input type="text" class="form-input w-full" @bind="CurrentMerchant.Name" placeholder="Business Name" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Contact Email</label>
                    <input type="email" class="form-input w-full" @bind="CurrentMerchant.ContactEmail" placeholder="email@business.com" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Address</label>
                    <input type="text" class="form-input w-full" @bind="CurrentMerchant.Address" placeholder="Physical Address" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Phone Number</label>
                    <input type="text" class="form-input w-full" @bind="CurrentMerchant.PhoneNumber" placeholder="e.g. +95 9..." />
                </div>

                @if (IsEditMode)
                {
                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="isActive" class="rounded border-gray-300 text-accent focus:ring-accent" @bind="IsActive" />
                        <label for="isActive" class="text-sm font-medium text-gray-700 dark:text-gray-300">Account Active</label>
                    </div>
                }
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface flex justify-end gap-3">
                <button @onclick="CloseModal" class="btn-ghost">Cancel</button>
                <button @onclick="SaveMerchant" class="btn-primary" disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></div>
                    }
                    @(IsEditMode ? "Save Changes" : "Create Merchant")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteConfirmModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[55] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-red-100 dark:border-red-900/30 bg-red-50 dark:bg-red-900/10 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                </div>
                <h3 class="text-base font-bold text-red-700 dark:text-red-400">Delete Merchant</h3>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-700 dark:text-gray-300">
                    Are you sure you want to delete <span class="font-semibold">@DeleteConfirmName</span>? This action cannot be undone.
                </p>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseDeleteConfirmModal" class="btn-ghost">Cancel</button>
                <button @onclick="ConfirmDelete" class="btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
}

@if (ShowForceDeleteModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden border border-red-500">
            <div class="px-6 py-4 border-b border-red-100 dark:border-red-900/30 flex items-center justify-between bg-red-50 dark:bg-red-900/10">
                <h3 class="text-lg font-bold text-red-600 dark:text-red-400">Warning: Active Dependencies Found</h3>
                <button @onclick="CloseForceDeleteModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6">
                <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">@ForceDeleteWarningMessage</p>
                <p class="text-sm text-gray-600 dark:text-gray-400">Are you absolutely sure you want to proceed? This will forcefully delete the merchant and cascade the deletion to all associated records. This action cannot be undone.</p>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface flex justify-end gap-3 flex-row-reverse border-t border-gray-100">
                <button @onclick="ConfirmForceDelete" class="btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Force Delete All
                </button>
                <button @onclick="CloseForceDeleteModal" class="btn-ghost">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<MerchantResponseDto> MerchantList = new();
    private CreateMerchantRequest CurrentMerchant = new();
    private Guid? EditingId;
    private bool IsActive = true;
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool ShowModal = false;
    private bool ShowDeleteConfirmModal = false;
    private Guid? DeleteConfirmId;
    private string DeleteConfirmName = "";
    private bool ShowForceDeleteModal = false;
    private Guid? ForceDeleteMerchantId;
    private string ForceDeleteWarningMessage = "";
    private bool IsEditMode = false;
    private string ErrorMessage = "";
    private string searchTerm = string.Empty;
    private bool IsSearching = false;
    private bool isGridView = true;
    private CancellationTokenSource? _searchCts;

    // Pagination
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int TotalRecords = 0;
    private int PageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadMerchants();
    }

    private async Task HandlePageChanged(int newPage)
    {
        CurrentPage = newPage;
        await LoadMerchants();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            CurrentPage = 1;
            await LoadMerchants(isSearching: true);
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task LoadMerchants(bool isSearching = false)
    {
        if (!isSearching) IsLoading = true;
        IsSearching = isSearching;
        ErrorMessage = "";
        try
        {
            var filter = new POS.Shared.Models.PaginationFilter 
            { 
                PageNumber = CurrentPage, 
                PageSize = PageSize,
                SearchTerm = searchTerm
            };
            var response = await MerchantService.GetAllMerchantsAsync(filter);
            if (response.IsSuccess && response.Data != null)
            {
                MerchantList = response.Data.Data.ToList();
                TotalPages = response.Data.TotalPages;
                TotalRecords = response.Data.TotalRecords;
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
            IsSearching = false;
        }
    }

    private void ShowAddModal()
    {
        IsEditMode = false;
        CurrentMerchant = new CreateMerchantRequest();
        ShowModal = true;
    }

    private void ShowEditModal(MerchantResponseDto merchant)
    {
        IsEditMode = true;
        EditingId = merchant.Id;
        IsActive = merchant.IsActive;
        CurrentMerchant = new CreateMerchantRequest
        {
            Name = merchant.Name,
            ContactEmail = merchant.ContactEmail,
            Address = merchant.Address,
            PhoneNumber = merchant.PhoneNumber,
        };
        ShowModal = true;
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private async Task SaveMerchant()
    {
        if (string.IsNullOrWhiteSpace(CurrentMerchant.Name)) return;

        IsSaving = true;
        try
        {
            bool success;
            if (IsEditMode && EditingId.HasValue)
            {
                var request = new UpdateMerchantRequest
                {
                    Id = EditingId.Value,
                    Name = CurrentMerchant.Name,
                    ContactEmail = CurrentMerchant.ContactEmail,
                    Address = CurrentMerchant.Address,
                    PhoneNumber = CurrentMerchant.PhoneNumber,
                    IsActive = IsActive
                };
                var response = await MerchantService.UpdateMerchantAsync(EditingId.Value, request);
                success = response.IsSuccess;
            }
            else
            {
                var response = await MerchantService.CreateMerchantAsync(CurrentMerchant);
                success = response.IsSuccess;
            }

            if (success)
            {
                ShowModal = false;
                await LoadMerchants();
            }
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ShowDeleteConfirm(Guid id, string name)
    {
        DeleteConfirmId = id;
        DeleteConfirmName = name;
        ShowDeleteConfirmModal = true;
    }

    private void CloseDeleteConfirmModal()
    {
        ShowDeleteConfirmModal = false;
        DeleteConfirmId = null;
    }

    private async Task ConfirmDelete()
    {
        if (!DeleteConfirmId.HasValue) return;
        var id = DeleteConfirmId.Value;
        ShowDeleteConfirmModal = false;
        DeleteConfirmId = null;
        await DeleteMerchant(id);
    }

    private async Task DeleteMerchant(Guid id)
    {
        var response = await MerchantService.DeleteMerchantAsync(id);
        if (response.IsSuccess)
        {
            await LoadMerchants();
        }
        else if (response.Message != null && response.Message.StartsWith("DependenciesExist:"))
        {
            ForceDeleteMerchantId = id;
            ForceDeleteWarningMessage = response.Message.Substring("DependenciesExist:".Length);
            ShowForceDeleteModal = true;
        }
        else
        {
            ErrorMessage = response.Message ?? "Error deleting merchant";
        }
    }

    private async Task ConfirmForceDelete()
    {
        if (ForceDeleteMerchantId.HasValue)
        {
            var response = await MerchantService.DeleteMerchantAsync(ForceDeleteMerchantId.Value, true);
            ShowForceDeleteModal = false;
            ForceDeleteMerchantId = null;
            
            if (response.IsSuccess)
            {
                await LoadMerchants();
            }
            else
            {
                ErrorMessage = response.Message ?? "Error force deleting merchant";
            }
        }
    }

    private void CloseForceDeleteModal()
    {
        ShowForceDeleteModal = false;
        ForceDeleteMerchantId = null;
    }
}
