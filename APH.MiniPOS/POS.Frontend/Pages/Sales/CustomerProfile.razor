@page "/customers/{Id:guid}"
@layout MainLayout
@using POS.Frontend.Models.Sales
@using POS.Frontend.Services.Sales
@using POS.Shared.Models
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,MerchantAdmin,Staff")]
@inject ICustomerService CustomerService
@inject ISaleService SaleService
@inject NavigationManager NavManager

<div class="space-y-6 max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 bg-slate-50/50 dark:bg-transparent min-h-screen">
    
    <!-- Top Nav -->
    <div class="flex items-center justify-between mb-8">
        <button class="flex items-center gap-2 text-xs font-bold bg-white dark:bg-surface text-gray-700 dark:text-gray-300 px-5 py-2.5 rounded-full shadow-sm hover:bg-gray-50 dark:hover:bg-gray-800 border border-gray-200 dark:border-gray-700 transition-colors" @onclick="NavigateBack">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            BACK TO DIRECTORY
        </button>
        <div class="flex items-center gap-3">
            <button class="bg-[#7048E8] text-white px-6 py-2.5 rounded-full text-xs font-bold hover:bg-purple-600 shadow-sm flex items-center gap-2 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                Edit Profile
            </button>
            <button class="bg-white dark:bg-surface text-gray-700 dark:text-gray-300 px-5 py-2.5 rounded-full text-xs font-bold hover:bg-red-50 dark:hover:bg-red-900/20 border border-gray-200 dark:border-gray-700 shadow-sm flex items-center gap-2 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                Delete
            </button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-purple-600"></div>
        </div>
    }
    else if (Customer == null)
    {
        <div class="text-center py-20 text-gray-500 font-semibold">Customer not found.</div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Column (Customer Info + Transactions) -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Customer Header Card -->
                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <div class="flex items-start gap-6">
                        <div class="w-24 h-24 rounded-[1.5rem] bg-[#F2EDFF] dark:bg-[#F2EDFF]/10 text-[#7048E8] flex items-center justify-center shrink-0">
                            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                        </div>
                        <div class="flex-1">
                            <div class="flex items-center gap-4 mb-1">
                                <h2 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight">@Customer.Name</h2>
                                <span class="bg-[#E0F9ED] dark:bg-[#1D9954]/20 text-[#1D9954] text-[10px] font-extrabold px-3 py-1 rounded-full tracking-widest uppercase">ACTIVE MEMBER</span>
                            </div>
                            <p class="text-xs font-bold text-[#7048E8] uppercase tracking-widest mb-6">MERCHANT: @Customer.MerchantName</p>
                            
                            <div class="flex flex-wrap items-center gap-10">
                                <div class="flex items-start gap-3">
                                    <div class="p-1.5 bg-gray-50 dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">PHONE NUMBER</p>
                                        <p class="text-sm font-bold text-gray-900 dark:text-gray-100 mt-0.5">@(string.IsNullOrEmpty(Customer.PhoneNumber) ? "N/A" : Customer.PhoneNumber)</p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-3">
                                    <div class="p-1.5 bg-gray-50 dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">EMAIL ADDRESS</p>
                                        <p class="text-sm font-bold text-gray-900 dark:text-gray-100 mt-0.5">@(string.IsNullOrEmpty(Customer.Email) ? "N/A" : Customer.Email)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transaction History Card -->
                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 flex items-center justify-center text-gray-500">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                            </div>
                            <h3 class="text-xl font-black text-gray-900 dark:text-white">Transaction History</h3>
                        </div>
                        <span class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 text-xs font-bold px-4 py-1.5 rounded-full">@Orders.Count Total Orders</span>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-100 dark:border-gray-800">
                                    <th class="pb-4">ORDER DATE</th>
                                    <th class="pb-4">ORDER ID</th>
                                    <th class="pb-4 text-right">AMOUNT</th>
                                    <th class="pb-4 text-center">ACTIONS</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                @if (!Orders.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-10 text-gray-400 font-medium">No transactions found</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var order in Orders)
                                    {
                                        <tr class="border-b border-gray-50 dark:border-gray-800/50 hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors">
                                            <td class="py-4">
                                                <p class="font-bold text-gray-900 dark:text-gray-100">@order.OrderDate.ToString("MMM dd, yyyy")</p>
                                                <p class="text-[10px] font-semibold text-gray-400">@order.OrderDate.ToString("hh:mm tt")</p>
                                            </td>
                                            <td class="py-4 font-bold text-gray-400 uppercase">
                                                <span class="bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded-md text-[10px]">@order.Id.ToString().Substring(0, 8)</span>
                                            </td>
                                            <td class="py-4 text-right font-black text-gray-900 dark:text-white">
                                                @order.TotalAmount.ToString("N0") <span class="text-[10px] font-bold text-gray-400 ml-1">MMK</span>
                                            </td>
                                            <td class="py-4 text-center">
                                                <button class="p-2 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-400 hover:text-purple-600 hover:border-purple-200 hover:bg-purple-50 transition-colors mx-auto block">
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Column (Metrics & Loyalty) -->
            <div class="space-y-6">
                
                <!-- Engagement Metrics Card -->
                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6">ENGAGEMENT METRICS</h3>
                    
                    <div class="bg-[#F8F5FF] dark:bg-[#F8F5FF]/5 rounded-[1.5rem] p-5 mb-4 border border-[#F2EDFF] dark:border-purple-900/20">
                        <p class="text-[10px] font-extrabold text-[#7048E8]/70 dark:text-[#7048E8] uppercase tracking-widest mb-1">LIFETIME VALUE</p>
                        <p class="text-3xl font-black text-[#7048E8]">@Orders.Sum(o => o.TotalAmount).ToString("N0") <span class="text-xs font-extrabold ml-1">MMK</span></p>
                    </div>

                    <div class="border border-gray-100 dark:border-gray-800 rounded-[1.5rem] p-5">
                        <p class="text-[10px] font-extrabold text-gray-400 uppercase tracking-widest mb-1">AVERAGE ORDER</p>
                        <p class="text-2xl font-black text-gray-900 dark:text-white">@(Orders.Any() ? Orders.Average(o => o.TotalAmount).ToString("N0") : "0") <span class="text-xs font-extrabold text-gray-400 ml-1">MMK</span></p>
                    </div>

                    <div class="mt-6 space-y-3 px-1">
                        <div class="flex justify-between items-center text-xs font-bold">
                            <span class="text-gray-400">Member Since</span>
                            <span class="text-gray-900 dark:text-white">@(Orders.Any() ? Orders.Min(o => o.OrderDate).ToString("MMM yyyy") : "N/A")</span>
                        </div>
                        <div class="flex justify-between items-center text-xs font-bold">
                            <span class="text-gray-400">Last Purchase</span>
                            <span class="text-gray-900 dark:text-white">@(Orders.Any() ? Orders.Max(o => o.OrderDate).ToString("MMM dd, yyyy") : "N/A")</span>
                        </div>
                    </div>
                </div>

                <!-- Loyalty Status Card -->
                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800 mt-10 relative">
                    <div class="w-16 h-16 bg-white dark:bg-surface rounded-full shadow-lg border border-gray-100 dark:border-gray-800 text-[#7048E8] mx-auto absolute -top-8 left-1/2 -translate-x-1/2 flex items-center justify-center">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
                    </div>
                    
                    <div class="pt-6 text-center">
                        <h3 class="text-2xl font-black text-gray-900 dark:text-white mb-2">@(LoyaltyAccount?.Tier ?? "Member")</h3>
                        <p class="text-[10px] font-bold text-gray-400">Loyalty status based on points activity.</p>
                    </div>

                    <div class="mt-8 border-t border-gray-100 dark:border-gray-800 pt-6 space-y-4 px-1">
                        <div class="flex justify-between items-center text-xs font-extrabold">
                            <span class="text-gray-400">Current Points</span>
                            <span class="text-gray-900 dark:text-white text-base">@(LoyaltyAccount?.CurrentBalance.ToString("N0") ?? "0")</span>
                        </div>
                        <div class="flex justify-between items-center text-xs font-extrabold">
                            <span class="text-gray-400">Lifetime Points</span>
                            <span class="text-gray-900 dark:text-white text-base">@(LoyaltyAccount?.TotalPointsEarned.ToString("N0") ?? "0")</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Rewards</h3>
                        @if (IsClaimingReward)
                        {
                            <span class="text-[10px] text-violet-500 font-bold">Claiming...</span>
                        }
                    </div>

                    @if (!ActiveRewards.Any())
                    {
                        <p class="text-sm text-gray-500">No active rewards configured for this merchant.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var reward in ActiveRewards.Where(r => r.IsActive).OrderBy(r => r.PointCost))
                            {
                                var canClaim = (LoyaltyAccount?.CurrentBalance ?? 0) >= reward.PointCost;
                                <div class="border border-gray-100 dark:border-gray-800 rounded-xl p-3">
                                    <div class="flex items-start justify-between gap-2">
                                        <div>
                                            <p class="font-bold text-gray-900 dark:text-white">@reward.Name</p>
                                            <p class="text-xs text-gray-500">@reward.Description</p>
                                        </div>
                                        <span class="text-xs font-black text-violet-600">@reward.PointCost.ToString("N0") pts</span>
                                    </div>
                                    <div class="mt-2 flex items-center justify-between">
                                        <span class="text-[10px] font-semibold @(canClaim ? "text-emerald-600" : "text-amber-600")">
                                            @(canClaim ? "Eligible to claim now" : $"Needs {(reward.PointCost - (LoyaltyAccount?.CurrentBalance ?? 0)):N0} more points")
                                        </span>
                                        <button class="text-xs px-3 py-1.5 rounded-lg font-bold @(canClaim ? "bg-violet-600 hover:bg-violet-700 text-white" : "bg-gray-100 text-gray-400 cursor-not-allowed")"
                                                disabled="@(!canClaim || IsClaimingReward)"
                                                @onclick="() => ClaimRewardFromProfile(reward)">
                                            Claim
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Points History</h3>
                    @if (!PointsHistory.Any())
                    {
                        <p class="text-sm text-gray-500">No points history yet.</p>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-100 dark:border-gray-800">
                                        <th class="pb-3">Date</th>
                                        <th class="pb-3">Activity</th>
                                        <th class="pb-3 text-right">Points</th>
                                    </tr>
                                </thead>
                                <tbody class="text-sm">
                                    @foreach (var item in PointsHistory)
                                    {
                                        <tr class="border-b border-gray-50 dark:border-gray-800/50">
                                            <td class="py-3 text-xs text-gray-500">@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                            <td class="py-3 font-semibold text-gray-900 dark:text-white">@(item.Description ?? item.EventKey ?? "Points update")</td>
                                            <td class="py-3 text-right font-black @(item.PointDelta >= 0 ? "text-emerald-600" : "text-red-600")">
                                                @(item.PointDelta >= 0 ? "+" : "")@item.PointDelta.ToString("N0")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="bg-white dark:bg-surface rounded-[2rem] p-8 shadow-[0_2px_20px_-5px_rgba(6,81,237,0.08)] border border-gray-100 dark:border-gray-800">
                    <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest mb-4">Claimed Rewards History</h3>
                    @if (!ClaimedRewardsHistory.Any())
                    {
                        <p class="text-sm text-gray-500">No claimed rewards yet.</p>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-100 dark:border-gray-800">
                                        <th class="pb-3">Date</th>
                                        <th class="pb-3">Reward</th>
                                        <th class="pb-3 text-center">Status</th>
                                        <th class="pb-3 text-right">Points Used</th>
                                    </tr>
                                </thead>
                                <tbody class="text-sm">
                                    @foreach (var item in ClaimedRewardsHistory)
                                    {
                                        <tr class="border-b border-gray-50 dark:border-gray-800/50">
                                            <td class="py-3 text-xs text-gray-500">@((item.RedeemedAt ?? item.CreatedAt).ToString("MMM dd, yyyy HH:mm"))</td>
                                            <td class="py-3 font-semibold text-gray-900 dark:text-white">@item.RewardName</td>
                                            <td class="py-3 text-center">
                                                <span class="px-2 py-1 rounded-full text-[10px] font-bold @(item.RedemptionStatus == "Fulfilled" ? "bg-emerald-100 text-emerald-700" : "bg-amber-100 text-amber-700")">
                                                    @(string.IsNullOrWhiteSpace(item.RedemptionStatus) ? "Claimed" : item.RedemptionStatus)
                                                </span>
                                            </td>
                                            <td class="py-3 text-right font-black text-red-600">@Math.Abs(item.PointDelta).ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }
    
    private bool IsLoading = true;
    private CustomerResponseDto? Customer;
    private LoyaltyAccountResponse? LoyaltyAccount;
    private List<OrderResponseDto> Orders = new();
    private List<LoyaltyReward> ActiveRewards = new();
    private List<LoyaltyHistoryDto> LoyaltyHistory = new();
    private bool IsClaimingReward = false;
    private List<LoyaltyHistoryDto> PointsHistory =>
        LoyaltyHistory
            .Where(h => string.IsNullOrWhiteSpace(h.RewardName))
            .OrderByDescending(h => h.CreatedAt)
            .ToList();

    private List<LoyaltyHistoryDto> ClaimedRewardsHistory =>
        LoyaltyHistory
            .Where(h => !string.IsNullOrWhiteSpace(h.RewardName))
            .OrderByDescending(h => h.RedeemedAt ?? h.CreatedAt)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            var customerRes = await CustomerService.GetCustomerByIdAsync(Id);
            if (customerRes.IsSuccess) Customer = customerRes.Data;

            if (Customer != null)
            {
                var loyaltyTask = CustomerService.GetCustomerLoyaltyAsync(Id);
                var rewardsTask = CustomerService.GetActiveRewardsAsync(customerId: Id);
                var historyTask = CustomerService.GetCustomerHistoryAsync(Id);
                await Task.WhenAll(loyaltyTask, rewardsTask, historyTask);

                if (loyaltyTask.Result.IsSuccess) LoyaltyAccount = loyaltyTask.Result.Data;
                if (rewardsTask.Result.IsSuccess && rewardsTask.Result.Data != null) ActiveRewards = rewardsTask.Result.Data;
                if (historyTask.Result.IsSuccess && historyTask.Result.Data != null) LoyaltyHistory = historyTask.Result.Data;
                
                var ordersRes = await SaleService.GetAllOrdersAsync(new PaginationFilter { PageSize = 1000 });
                if (ordersRes.IsSuccess && ordersRes.Data?.Data != null)
                {
                    Orders = ordersRes.Data.Data.Where(o => o.CustomerId == Id).OrderByDescending(o => o.OrderDate).ToList();
                }
            }
        }
        finally
        {
            IsLoading = false;
        }
    }
    
    private void NavigateBack()
    {
        NavManager.NavigateTo("/customers");
    }

    private async Task ClaimRewardFromProfile(LoyaltyReward reward)
    {
        if (Customer == null || LoyaltyAccount == null || IsClaimingReward)
        {
            return;
        }

        if (LoyaltyAccount.CurrentBalance < reward.PointCost)
        {
            return;
        }

        IsClaimingReward = true;
        try
        {
            var claimResult = await CustomerService.ClaimRewardAsync(new ClaimRewardRequest
            {
                CustomerId = Customer.Id,
                RewardId = reward.Id,
                Notes = $"Claimed from customer profile: {Customer.Name}"
            });

            if (claimResult.IsSuccess)
            {
                var loyaltyRes = await CustomerService.GetCustomerLoyaltyAsync(Customer.Id);
                if (loyaltyRes.IsSuccess)
                {
                    LoyaltyAccount = loyaltyRes.Data;
                }

                var historyRes = await CustomerService.GetCustomerHistoryAsync(Customer.Id);
                if (historyRes.IsSuccess && historyRes.Data != null)
                {
                    LoyaltyHistory = historyRes.Data;
                }
            }
        }
        finally
        {
            IsClaimingReward = false;
        }
    }
}
