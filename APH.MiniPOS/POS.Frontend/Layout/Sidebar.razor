@inject NavigationManager Nav
@inject POS.Frontend.Services.Auth.IAuthService AuthService

<aside class="flex flex-col w-60 shrink-0 bg-sidebar h-full sidebar-scroll overflow-y-auto">

    <!-- Brand -->
    <div class="flex items-center gap-3 px-5 py-5 border-b border-dark-border">
        <div class="w-8 h-8 rounded-lg bg-accent shadow-neon flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
        </div>
        <div>
            <p class="text-white font-semibold text-sm leading-tight text-shadow-neon">MiniPOS</p>
            <p class="text-accent-light text-xs">v1.0</p>
        </div>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-6">

        <!-- Sales -->
        <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-widest px-3 mb-2">Sales</p>
            <div class="space-y-0.5">
                <NavLink href="" Match="NavLinkMatch.All" class="nav-item" ActiveClass="active">
                    @HomeIcon
                    Dashboard
                </NavLink>
                <AuthorizeView Roles="Admin, MerchantAdmin, Staff">
                    <Authorized>
                        <NavLink href="sales" class="nav-item" ActiveClass="active">
                            @ReceiptIcon
                            Sales History
                        </NavLink>
                        <NavLink href="sales/terminal" class="nav-item" ActiveClass="active">
                            @PosIcon
                            POS Terminal
                        </NavLink>
                        <NavLink href="customers" class="nav-item" ActiveClass="active">
                            @UsersIcon
                            Customers
                        </NavLink>
                        <a href="http://150.95.88.91:4200/" target="_blank" class="nav-item">
                            @GiftIcon
                            Reward Portal
                            <svg class="w-3 h-3 ml-auto opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <!-- Management -->
        <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-widest px-3 mb-2">Management</p>
            <div class="space-y-0.5">
                <AuthorizeView Roles="Admin, MerchantAdmin, Staff">
                    <Authorized>
                        <NavLink href="products" class="nav-item" ActiveClass="active">
                            @BoxIcon
                            Products
                        </NavLink>
                        <NavLink href="categories" class="nav-item" ActiveClass="active">
                            @TagIcon
                            Categories
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Roles="Admin, MerchantAdmin">
                    <Authorized>
                        <NavLink href="branches" class="nav-item" ActiveClass="active">
                            @BuildingIcon
                            Branches
                        </NavLink>
                        <NavLink href="management/loyalty" class="nav-item" ActiveClass="active">
                            @GiftIcon
                            Loyalty Admin
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Roles="Admin, MerchantAdmin">
                    <Authorized>
                        @if (context.User.IsInRole("Admin"))
                        {
                            <NavLink href="merchants" class="nav-item" ActiveClass="active">
                                @StoreIcon
                                Merchants
                            </NavLink>
                        }
                        <NavLink href="restoration" class="nav-item" ActiveClass="active">
                            @RestoreIcon
                            Restoration
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <!-- User Settings -->
        <div>
            <p class="text-xs font-semibold text-muted uppercase tracking-widest px-3 mb-2">User Settings</p>
            <div class="space-y-0.5">
                <AuthorizeView Roles="Admin, MerchantAdmin, Staff">
                    <Authorized>
                        <NavLink href="settings/users" class="nav-item" ActiveClass="active">
                            @ShieldIcon
                            User Management
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
                <NavLink href="settings/profile" class="nav-item" ActiveClass="active">
                    @ProfileIcon
                    My Profile
                </NavLink>
            </div>
        </div>

    </nav>

    <!-- Bottom user chip -->
    <AuthorizeView>
        <Authorized>
            <div class="px-3 py-4 border-t border-dark-border">
                <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-sidebar-hover border border-border/10 cursor-pointer hover:bg-dark-border transition-colors">
                    <div class="flex items-center gap-3 overflow-hidden">
                        <div class="w-8 h-8 rounded-full bg-accent/20 border border-accent/40 shadow-neon flex items-center justify-center shrink-0">
                            <span class="text-accent-light text-xs font-semibold">@(string.IsNullOrEmpty(context.User.Identity?.Name) ? "" : context.User.Identity.Name.Substring(0, 1).ToUpper())</span>
                        </div>
                        <div class="min-w-0">
                            <p class="text-white text-xs font-medium truncate">@(string.IsNullOrEmpty(context.User.Identity?.Name) ? "User" : context.User.Identity.Name)</p>
                            <p class="text-muted text-[10px] truncate uppercase tracking-wider">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                        </div>
                    </div>
                    <button class="text-gray-400 hover:text-white" @onclick="Logout" title="Logout">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </button>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

</aside>

@code {
    private RenderFragment HomeIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>;
    private RenderFragment ReceiptIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>;
    private RenderFragment PosIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7H6a2 2 0 00-2 2v9a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>;
    private RenderFragment UsersIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>;
    private RenderFragment BoxIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>;
    private RenderFragment TagIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>;
    private RenderFragment WarehouseIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>;
    private RenderFragment BuildingIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>;
    private RenderFragment StoreIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" /></svg>;
    private RenderFragment ShieldIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>;
    private RenderFragment ProfileIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>;
    private RenderFragment RestoreIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" /></svg>;
    private RenderFragment GiftIcon =>@<svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V6a2 2 0 10-2 2h2zm0 0l4 4M12 21h8a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>;

    async Task Logout()
    {
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
