@page "/categories"
@layout MainLayout
@inject ICategoryService CategoryService
@inject IMerchantService MerchantService
@using POS.Frontend.Models.Categories
@using POS.Frontend.Models.Merchants
@using POS.Frontend.Services.Categories
@using POS.Frontend.Services.Merchants
@using POS.Shared.Models
@inject NavigationManager NavManager

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Categories</h2>
            <p class="page-subtitle">Organize your product categories</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Category
        </button>
    </div>

    <div class="card">
        <div class="card-header shrink-0 p-4 border-b border-gray-100 dark:border-gray-800">
            <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between w-full">
                <div class="flex gap-3 flex-wrap items-center">
                    <div class="relative max-w-sm">
                        <input type="text" 
                               class="form-input w-full pl-10" 
                               placeholder="Search categories..." 
                               @bind-value="_searchTerm"
                               @bind-value:event="oninput"
                               @onkeyup="HandleSearch" />
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        </div>
                        @if (_isSearching)
                        {
                            <div class="absolute right-3 top-1/2 -translate-y-1/2">
                                <div class="w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                            </div>
                        }
                    </div>
                </div>

                <!-- View Toggle -->
                <div class="flex bg-gray-100 dark:bg-gray-800 p-1 rounded-lg shrink-0">
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(!isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = false">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
                        List
                    </button>
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = true">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                        Grid
                    </button>
                </div>
            </div>
        </div>
        <div class="flex-1 overflow-y-auto px-4 sm:px-6 py-4">
        @if (!isGridView)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Products</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="relative">
                    @if (_isLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8">
                                <div class="flex flex-col items-center justify-center text-muted">
                                    <svg class="animate-spin h-8 w-8 text-primary mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <p>Loading categories...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-red-500">
                                <p>@_errorMessage</p>
                                <button class="btn-secondary mt-4" @onclick="() => LoadCategories()">Try Again</button>
                            </td>
                        </tr>
                    }
                    else if (!CategoryList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-muted">
                                <p>No categories found.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in CategoryList)
                        {
                            <tr class="cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors" @onclick="() => NavigateToProducts(c.Id)">
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-sm">@CategoryIconHelper.GetIcon(c.Name)</div>
                                        <span class="font-medium text-gray-800 dark:text-gray-200">@c.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted">@c.Description</td>
                                <td>@c.ProductCount products</td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => OpenEditModal(c)" @onclick:stopPropagation>Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => ShowDeleteConfirm(c.Id, c.Name)" @onclick:stopPropagation>Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                @foreach (var c in CategoryList)
                {
                    <div class="group bg-white dark:bg-surface border border-gray-100 dark:border-gray-800 rounded-2xl p-4 hover:shadow-xl hover:border-accent/20 transition-all cursor-pointer" @onclick="() => NavigateToProducts(c.Id)">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-indigo-50 flex items-center justify-center text-xl text-indigo-500 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                                @CategoryIconHelper.GetIcon(c.Name)
                            </div>
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-1 truncate">@c.Name</h4>
                            <p class="text-sm text-gray-400 mb-3 line-clamp-2 min-h-[40px]">@(string.IsNullOrEmpty(c.Description) ? "No description" : c.Description)</p>
                            <p class="font-semibold text-accent">@c.ProductCount products</p>
                        </div>
                        <div class="flex gap-2 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
                            <button class="btn-secondary flex-1 py-1.5 text-xs justify-center" @onclick="() => OpenEditModal(c)" @onclick:stopPropagation>Edit</button>
                            <button class="btn-danger flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowDeleteConfirm(c.Id, c.Name)" @onclick:stopPropagation>Delete</button>
                        </div>
                    </div>
                }
            </div>
        }
        </div>
        @if (!_isLoading && _totalRecords > 0)
        {
            <div class="mt-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                <Pagination CurrentPage="_currentPage"
                            TotalPages="_totalPages"
                            TotalRecords="_totalRecords"
                            PageSize="_pageSize"
                            OnPageChanged="HandlePageChanged" />
            </div>
        }
    </div>

    @if (showModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
            <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden animate-fade-in">
                <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                    <h3 class="text-lg font-bold text-gray-800 dark:text-gray-200">@(isEditMode ? "Edit Category" : "Add New Category")</h3>
                    <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Category Name</label>
                        <input type="text" @bind="formModel.Name" class="form-input" placeholder="e.g. Beverages" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Description</label>
                        <textarea @bind="formModel.Description" class="form-input h-24" placeholder="Optional description..."></textarea>
                    </div>
                    @if (!isEditMode && MerchantList.Count > 1)
                    {
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Merchant</label>
                            <select @bind="formModel.MerchantIdString" class="form-input">
                                @foreach (var m in MerchantList)
                                {
                                    <option value="@m.Id.ToString()">@m.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 flex justify-end gap-3">
                    <button @onclick="CloseModal" class="btn-secondary">Cancel</button>
                    <button @onclick="SaveCategory" class="btn-primary" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <svg class="animate-spin h-4 w-4 mr-2" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        }
                        @(isEditMode ? "Update Category" : "Create Category")
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@if (showDeleteConfirmModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[55] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-red-100 dark:border-red-900/30 bg-red-50 dark:bg-red-900/10 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                </div>
                <h3 class="text-base font-bold text-red-700 dark:text-red-400">Delete Category</h3>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-700 dark:text-gray-300">
                    Are you sure you want to delete <span class="font-semibold">@_deleteConfirmName</span>? All products in this category may be affected.
                </p>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseDeleteConfirm" class="btn-ghost">Cancel</button>
                <button @onclick="ConfirmDelete" class="btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CategoryResponseDto> CategoryList = new();

    private void NavigateToProducts(Guid categoryId)
    {
        NavManager.NavigateTo($"/products?categoryIdQuery={categoryId}");
    }

    private List<MerchantResponseDto> MerchantList = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool showModal = false;
    private bool isEditMode = false;
    private bool _isSaving = false;
    private bool showDeleteConfirmModal = false;
    private Guid _deleteConfirmId;
    private string _deleteConfirmName = "";
    private string _searchTerm = "";
    private bool _isSearching = false;
    private bool isGridView = true;
    private CancellationTokenSource? _searchCts;
    private CategoryFormModel formModel = new();

    // Pagination
    private int _currentPage = 1;
    private int _totalPages = 1;
    private int _totalRecords = 0;
    private int _pageSize = 10;

    private class CategoryFormModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public Guid MerchantId { get; set; }

        public string MerchantIdString
        {
            get => MerchantId == Guid.Empty ? "" : MerchantId.ToString();
            set => MerchantId = Guid.TryParse(value, out var guid) ? guid : Guid.Empty;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCategories(), LoadMerchants());
    }

    private async Task LoadMerchants()
    {
        var response = await MerchantService.GetAllMerchantsAsync(new PaginationFilter { PageSize = 100 });
        if (response?.Data?.Data != null)
        {
            MerchantList = response.Data.Data.ToList();
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        _currentPage = newPage;
        await LoadCategories();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            _currentPage = 1;
            await LoadCategories(isSearching: true);
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task LoadCategories(bool isSearching = false)
    {
        if (!isSearching) _isLoading = true;
        _isSearching = isSearching;
        _errorMessage = null;

        var filter = new PaginationFilter 
        { 
            PageNumber = _currentPage, 
            PageSize = _pageSize,
            SearchTerm = _searchTerm
        };
        var response = await CategoryService.GetCategoriesAsync(filter);
        if (response?.IsSuccess == true && response.Data != null)
        {
            CategoryList = response.Data.Data.ToList();
            _totalPages = response.Data.TotalPages;
            _totalRecords = response.Data.TotalRecords;
        }
        else
        {
            _errorMessage = response?.Message ?? "Unknown error occurred";
        }
        _isLoading = false;
    }

    private void OpenAddModal()
    {
        isEditMode = false;
        formModel = new CategoryFormModel
        {
            MerchantId = MerchantList.FirstOrDefault()?.Id ?? Guid.Empty
        };
        showModal = true;
    }

    private void OpenEditModal(CategoryResponseDto c)
    {
        isEditMode = true;
        formModel = new CategoryFormModel
        {
            Id = c.Id,
            Name = c.Name,
            Description = c.Description
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(formModel.Name)) return;

        _isSaving = true;
        _errorMessage = null;

        if (isEditMode)
        {
            var request = new UpdateCategoryRequest
            {
                Id = formModel.Id,
                Name = formModel.Name,
                Description = formModel.Description
            };
            var result = await CategoryService.UpdateCategoryAsync(request);
            if (result.IsSuccess)
            {
                showModal = false;
                await LoadCategories();
            }
            else
            {
                _errorMessage = result.Message;
            }
        }
        else
        {
            var request = new CreateCategoryRequest
            {
                Name = formModel.Name,
                Description = formModel.Description,
                MerchantId = formModel.MerchantId
            };
            var result = await CategoryService.CreateCategoryAsync(request);
            if (result.IsSuccess)
            {
                showModal = false;
                await LoadCategories();
            }
            else
            {
                _errorMessage = result.Message;
            }
        }

        _isSaving = false;
    }

    private void ShowDeleteConfirm(Guid id, string name)
    {
        _deleteConfirmId = id;
        _deleteConfirmName = name;
        showDeleteConfirmModal = true;
    }

    private void CloseDeleteConfirm()
    {
        showDeleteConfirmModal = false;
    }

    private async Task ConfirmDelete()
    {
        showDeleteConfirmModal = false;
        await DeleteCategory(_deleteConfirmId);
    }

    private async Task DeleteCategory(Guid id)
    {
        var result = await CategoryService.DeleteCategoryAsync(id);
        if (result.IsSuccess)
        {
            await LoadCategories();
        }
        else
        {
            _errorMessage = result.Message;
        }
    }
}
