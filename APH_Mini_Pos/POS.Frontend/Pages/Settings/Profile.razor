@page "/settings/profile"
@layout MainLayout
@using Microsoft.AspNetCore.Components.Authorization
@using POS.Frontend.Services.Users
@using POS.Frontend.Models.Users
@using POS.Shared.Models
@using POS.Frontend.Models.Merchants
@using POS.Frontend.Models.Sales
@using POS.Frontend.Services.Sales
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject POS.Frontend.Services.Merchants.IMerchantService MerchantService
@inject POS.Frontend.Services.Merchants.IBranchService BranchService
@inject ISaleService SaleService

<div class="max-w-5xl mx-auto space-y-6">

    <div class="page-header">
        <div>
            <h2 class="page-title">My Profile</h2>
            <p class="page-subtitle">Manage your personal settings and view your performance</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="flex items-center justify-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-accent"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left Side: Profile Summary & Stats -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Profile Summary Card -->
                <div class="card overflow-hidden">
                    <div class="h-24 bg-gradient-to-r from-accent to-indigo-600"></div>
                    <div class="px-6 pb-6 -mt-12 text-center">
                        <div class="relative inline-block">
                            <div class="w-24 h-24 rounded-full border-4 border-white dark:border-surface bg-gradient-to-br from-accent to-indigo-500 text-white flex items-center justify-center text-4xl font-bold shadow-xl overflow-hidden mb-4">
                                <img src="@AvatarUrl" alt="Avatar" class="w-full h-full object-cover" />
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">@(!string.IsNullOrEmpty(fullName) ? fullName : username)</h3>
                        <p class="text-sm text-muted mb-4 uppercase tracking-wider font-medium">@role</p>
                        
                        <div class="flex flex-wrap justify-center gap-2 mb-6">
                            @if (role == "Admin")
                            {
                                <span class="badge bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300">System Admin</span>
                            }
                            else if (role == "MerchantAdmin")
                            {
                                <span class="badge badge-info">Merchant Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-gray-100 dark:bg-border/30 text-gray-700 dark:text-gray-300">Store Staff</span>
                            }
                            <span class="badge @(isActive ? "badge-success" : "badge-danger")">@(isActive ? "Active Account" : "Inactive")</span>
                        </div>

                        <div class="grid grid-cols-2 gap-4 pt-6 border-t border-border">
                            <div>
                                <p class="text-lg font-bold text-accent">@totalSalesCount</p>
                                <p class="text-[10px] text-muted uppercase tracking-widest font-semibold">Total Sales</p>
                            </div>
                            <div>
                                <p class="text-lg font-bold text-indigo-500">@totalSalesAmount.ToString("N0")</p>
                                <p class="text-[10px] text-muted uppercase tracking-widest font-semibold">MMK Total</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Managed Context Info -->
                <div class="card p-5 space-y-4">
                    <h4 class="text-xs font-bold text-muted uppercase tracking-widest">Workspace</h4>
                    @if (!string.IsNullOrEmpty(merchantNameDisplay))
                    {
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center text-indigo-600 dark:text-indigo-400">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                            </div>
                            <div class="min-w-0">
                                <p class="text-xs text-muted">Merchant</p>
                                <p class="text-sm font-semibold text-gray-700 dark:text-gray-300 truncate">@merchantNameDisplay</p>
                            </div>
                        </div>
                    }
                    @if (role == "MerchantAdmin" && merchantBranches.Any())
                    {
                        <div class="space-y-3 pt-2">
                            <p class="text-[10px] text-muted uppercase tracking-widest font-bold mb-1">Managed Branches (@merchantBranches.Count)</p>
                            <div class="grid grid-cols-1 gap-2">
                                @foreach (var branch in merchantBranches)
                                {
                                    <div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-gray-50 dark:bg-border/10 border border-gray-100 dark:border-border/20">
                                        <div class="w-2 h-2 rounded-full bg-accent"></div>
                                        <span class="text-xs font-medium text-gray-700 dark:text-gray-300">@branch.Name</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(branchNameDisplay))
                    {
                        <div class="flex items-center gap-3 border-t border-border pt-4">
                            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center text-accent">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            </div>
                            <div class="min-w-0">
                                <p class="text-xs text-muted">Assigned Branch</p>
                                <p class="text-sm font-semibold text-gray-700 dark:text-gray-300 truncate">@branchNameDisplay</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Right Side: Details & Forms -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Personal Details Tab -->
                <div class="card">
                    <div class="card-header border-none pb-0">
                        <div class="flex items-center gap-2">
                            <div class="w-1.5 h-6 bg-accent rounded-full"></div>
                            <h3 class="text-base font-bold text-gray-900 dark:text-gray-100">Personal Details</h3>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6">
                            <div class="space-y-1">
                                <label class="text-xs font-bold text-muted uppercase">Full Name</label>
                                <input type="text" class="form-input" @bind="editFullName" placeholder="Your Name" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-bold text-muted uppercase">Email</label>
                                <input type="email" class="form-input" @bind="editEmail" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-bold text-muted uppercase">Phone Number</label>
                                <input type="text" class="form-input" @bind="editPhoneNumber" />
                            </div>
                            <div class="space-y-1 opacity-50">
                                <label class="text-xs font-bold text-muted uppercase">Username</label>
                                <input type="text" class="form-input bg-gray-50 dark:bg-surface" value="@username" disabled />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(infoMessage))
                        {
                            <div class="mb-4 p-3 rounded-xl border @(infoIsError ? "bg-red-50 border-red-100 text-red-700" : "bg-green-50 border-green-100 text-green-700") text-xs flex items-center gap-2">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                @infoMessage
                            </div>
                        }

                        <div class="flex justify-end">
                            <button class="btn-primary" @onclick="SaveProfile" disabled="@isSavingProfile">
                                @if (isSavingProfile) { <div class="w-4 h-4 shadow-neon border-2 border-white/30 border-t-white rounded-full animate-spin mr-2 inline-block align-middle"></div> }
                                Update Information
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="card overflow-hidden">
                    <div class="card-header border-none pb-0">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-1.5 h-6 bg-indigo-500 rounded-full"></div>
                                <h3 class="text-base font-bold text-gray-900 dark:text-gray-100">Your Recent Activity</h3>
                            </div>
                            <a href="sales" class="text-accent text-xs hover:underline">View All Sales</a>
                        </div>
                    </div>
                    <div class="card-body px-0">
                        <div class="overflow-x-auto">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th class="pl-6">Sale ID</th>
                                        <th>Date</th>
                                        <th>Total</th>
                                        <th class="pr-6 text-right">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!recentOrders.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-10 text-muted italic">No recent sales processed by you</td>
                                        </tr>
                                    }
                                    @foreach (var order in recentOrders)
                                    {
                                        <tr>
                                            <td class="pl-6 font-mono text-[11px] text-muted">@order.Id.ToString().Substring(0, 8)...</td>
                                            <td class="text-xs">@order.OrderDate.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                            <td class="font-bold text-gray-700 dark:text-gray-300">@order.TotalAmount.ToString("N0")</td>
                                            <td class="pr-6 text-right"><span class="badge badge-success">Completed</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Security / Password -->
                <div class="card">
                    <div class="card-header border-none pb-0">
                        <div class="flex items-center gap-2">
                            <div class="w-1.5 h-6 bg-red-500 rounded-full"></div>
                            <h3 class="text-base font-bold text-gray-900 dark:text-gray-100">Security & Password</h3>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <label class="text-xs font-bold text-muted uppercase mb-1 block">Current Password</label>
                                <input type="password" class="form-input" @bind="oldPassword" />
                            </div>
                            <div>
                                <label class="text-xs font-bold text-muted uppercase mb-1 block">New Password</label>
                                <input type="password" class="form-input" @bind="newPassword" />
                            </div>
                            <div>
                                <label class="text-xs font-bold text-muted uppercase mb-1 block">Confirm</label>
                                <input type="password" class="form-input" @bind="confirmPassword" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(passwordMessage))
                        {
                            <div class="mt-4 p-3 rounded-xl border @(passwordIsError ? "bg-red-50 border-red-100 text-red-700" : "bg-green-50 border-green-100 text-green-700") text-xs">
                                @passwordMessage
                            </div>
                        }

                        <div class="flex justify-end mt-6">
                            <button class="btn-secondary" @onclick="UpdatePassword" disabled="@isSavingPassword">
                                @if (isSavingPassword) { <div class="w-4 h-4 border-2 border-current/30 border-t-current rounded-full animate-spin mr-2 inline-block align-middle"></div> }
                                Change Password
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSavingProfile = false;
    private bool isSavingPassword = false;

    private string userId = "";
    private string username = "";
    private string email = "";
    private string fullName = "";
    private string phoneNumber = "";
    private string role = "";
    private bool isActive = true;
    
    private string merchantNameDisplay = "";
    private string branchNameDisplay = "";

    // Stats
    private int totalSalesCount = 0;
    private decimal totalSalesAmount = 0;
    private List<OrderResponseDto> recentOrders = new();
    private List<BranchResponseDto> merchantBranches = new();

    // Editable fields
    private string editEmail = "";
    private string editFullName = "";
    private string editPhoneNumber = "";
    private string oldPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";

    // Status messages
    private string infoMessage = "";
    private bool infoIsError = false;
    private string passwordMessage = "";
    private bool passwordIsError = false;

    private Guid? currentUserId;

    // Avatar Logic (Dynamic placeholder based on name)
    private string AvatarUrl => $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(!string.IsNullOrEmpty(fullName) ? fullName : username)}&background=random&size=256";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        username = user.Identity?.Name ?? "User";
        role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Staff";

        var idClaim = user.FindFirst("UserId")?.Value ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        userId = idClaim ?? "";

        if (Guid.TryParse(userId, out var uid))
        {
            currentUserId = uid;
            await LoadUserProfile();
            await LoadUserStats();
            if (role == "MerchantAdmin" && currentUserId.HasValue)
            {
                await LoadMerchantBranches();
            }
        }

        isLoading = false;
    }

    private async Task LoadUserProfile()
    {
        try
        {
            var response = await UserService.GetUserByIdAsync(currentUserId.Value);
            if (response.IsSuccess && response.Data != null)
            {
                email = response.Data.Email;
                editEmail = email;
                fullName = response.Data.FullName ?? "";
                editFullName = fullName;
                phoneNumber = response.Data.PhoneNumber ?? "";
                editPhoneNumber = phoneNumber;
                isActive = response.Data.IsActive;
                merchantNameDisplay = response.Data.MerchantName ?? "";
                branchNameDisplay = response.Data.BranchName ?? "";
            }
        }
        catch { }
    }

    private async Task LoadUserStats()
    {
        try
        {
            var filter = new PaginationFilter 
            { 
                ProcessedById = currentUserId.Value,
                PageSize = 5
            };
            
            var response = await SaleService.GetAllOrdersAsync(filter);
            if (response.IsSuccess && response.Data != null)
            {
                recentOrders = response.Data.Data.ToList();
                totalSalesCount = response.Data.TotalRecords;
                totalSalesAmount = response.Data.Data.Sum(o => o.TotalAmount);
            }
        }
        catch { }
    }

    private async Task LoadMerchantBranches()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var merchantClaim = authState.User.FindFirst("MerchantId")?.Value;
            if (Guid.TryParse(merchantClaim, out var mId))
            {
                var response = await BranchService.GetBranchesByMerchantIdAsync(mId, new PaginationFilter { PageSize = 50 });
                if (response.IsSuccess && response.Data != null)
                {
                    merchantBranches = response.Data.Data.ToList();
                }
            }
        }
        catch { }
    }

    private async Task SaveProfile()
    {
        if (!currentUserId.HasValue) return;
        isSavingProfile = true;
        infoMessage = "";

        try
        {
            var request = new UpdateUserRequest 
            { 
                Email = editEmail,
                FullName = editFullName,
                PhoneNumber = editPhoneNumber
            };
            var response = await UserService.UpdateUserAsync(currentUserId.Value, request);
            if (response.IsSuccess)
            {
                email = editEmail;
                fullName = editFullName;
                infoMessage = "Profile updated successfully!";
                infoIsError = false;
            }
            else
            {
                infoMessage = response.Message ?? "Failed to update profile.";
                infoIsError = true;
            }
        }
        catch (Exception ex)
        {
            infoMessage = $"Error: {ex.Message}";
            infoIsError = true;
        }
        finally
        {
            isSavingProfile = false;
        }
    }

    private async Task UpdatePassword()
    {
        passwordMessage = "";

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordMessage = "Please enter a new password.";
            passwordIsError = true;
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordMessage = "Passwords do not match.";
            passwordIsError = true;
            return;
        }

        isSavingPassword = true;

        try
        {
            var request = new UpdateUserRequest { PlainPassword = newPassword };
            var response = await UserService.UpdateUserAsync(currentUserId.Value, request);
            if (response.IsSuccess)
            {
                passwordMessage = "Password updated successfully!";
                passwordIsError = false;
                newPassword = "";
                confirmPassword = "";
                oldPassword = "";
            }
            else
            {
                passwordMessage = response.Message ?? "Failed to update password.";
                passwordIsError = true;
            }
        }
        catch (Exception ex)
        {
            passwordMessage = $"Error: {ex.Message}";
            passwordIsError = true;
        }
        finally
        {
            isSavingPassword = false;
        }
    }
}
