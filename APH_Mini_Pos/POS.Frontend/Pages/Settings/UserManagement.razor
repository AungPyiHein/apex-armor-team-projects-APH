@page "/settings/users"
@attribute [Authorize]
@layout MainLayout
@using POS.Frontend.Services.Users
@using POS.Frontend.Models.Users
@using POS.Frontend.Models.Merchants
@using POS.Shared.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject POS.Frontend.Services.Merchants.IBranchService BranchService
@inject POS.Frontend.Services.Merchants.IMerchantService MerchantService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">User Management</h2>
            <p class="page-subtitle">Manage staff access and roles</p>
        </div>
        <button class="btn-primary" @onclick="ShowInviteModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
            Create User
        </button>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage) && !ShowModal)
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl flex items-center justify-between">
            <span class="text-red-700 text-sm">@ErrorMessage</span>
            <button class="text-red-500 hover:text-red-700 font-bold" @onclick="@(() => ErrorMessage = "")">✕</button>
        </div>
    }

    <div class="card">
        <div class="card-header shrink-0 p-4 border-b border-gray-100 dark:border-gray-800">
            <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between w-full">
                <div class="flex gap-3 flex-wrap items-center">
                    <div class="relative max-w-sm">
                        <input type="text" 
                               class="form-input w-full pl-10" 
                               placeholder="Search users by name or email..." 
                               @bind-value="_searchTerm"
                               @bind-value:event="oninput"
                               @onkeyup="HandleSearch" />
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        </div>
                        @if (_isSearching)
                        {
                            <div class="absolute right-3 top-1/2 -translate-y-1/2">
                                <div class="w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                            </div>
                        }
                    </div>
                </div>

                <!-- View Toggle -->
                <div class="flex bg-gray-100 dark:bg-gray-800 p-1 rounded-lg shrink-0">
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(!isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = false">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
                        List
                    </button>
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = true">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                        Grid
                    </button>
                </div>
            </div>
        </div>
        <div class="flex-1 overflow-y-auto px-4 sm:px-6 py-4">
        @if (!isGridView)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Context</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="relative">
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10">
                                <div class="flex justify-center">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!UserList.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10 text-muted italic">No users found</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var u in UserList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
                                            <span class="text-accent text-xs font-semibold">@u.Username[0]</span>
                                        </div>
                                        <div>
                                            <p class="text-sm font-medium text-gray-900 dark:text-gray-100">@(!string.IsNullOrEmpty(u.FullName) ? u.FullName : u.Username)</p>
                                            <p class="text-xs text-muted">@u.Email @(!string.IsNullOrEmpty(u.PhoneNumber) ? $" | {u.PhoneNumber}" : "")</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(u.MerchantName) || !string.IsNullOrEmpty(u.BranchName))
                                    {
                                        <div class="flex flex-col">
                                            @if (!string.IsNullOrEmpty(u.MerchantName))
                                            {
                                                <span class="text-xs text-gray-900 dark:text-gray-100 font-medium">@u.MerchantName</span>
                                            }
                                            @if (!string.IsNullOrEmpty(u.BranchName))
                                            {
                                                <span class="text-xs text-muted">@u.BranchName</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-muted italic">System</span>
                                    }
                                </td>
                                <td>
                                    @if (u.Role == "Admin")
                                    { <span class="badge bg-purple-100 text-purple-700">@u.Role</span> }
                                    else if (u.Role == "MerchantAdmin")
                                    { <span class="badge badge-info">Merchant Admin</span> }
                                    else
                                    { <span class="badge bg-gray-100 dark:bg-border/30 text-gray-700 dark:text-gray-300">@u.Role</span> }
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    { <span class="badge badge-success">Active</span> }
                                    else
                                    { <span class="badge badge-warning">Inactive</span> }
                                </td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => ShowEditModal(u)">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => ShowRevokeConfirm(u.Id, u.FullName ?? u.Username)">Revoke</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                @foreach (var u in UserList)
                {
                    <div class="group bg-white dark:bg-surface border border-gray-100 dark:border-gray-800 rounded-2xl p-4 hover:shadow-xl hover:border-accent/20 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center text-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
                                <span class="font-bold">@u.Username[0]</span>
                            </div>
                            @if (u.IsActive)
                            { <span class="badge badge-success">Active</span> }
                            else
                            { <span class="badge badge-warning">Inactive</span> }
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-1 truncate">@(!string.IsNullOrEmpty(u.FullName) ? u.FullName : u.Username)</h4>
                            <p class="text-sm text-gray-400 mb-2 truncate">@u.Username | @u.Email</p>
                            @if (!string.IsNullOrEmpty(u.PhoneNumber))
                            {
                                <p class="text-xs text-gray-400 mb-2 truncate"><svg class="w-3 h-3 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>@u.PhoneNumber</p>
                            }
                            @if (!string.IsNullOrEmpty(u.MerchantName) || !string.IsNullOrEmpty(u.BranchName))
                            {
                                <div class="mb-3 space-y-1">
                                    @if (!string.IsNullOrEmpty(u.MerchantName))
                                    {
                                        <p class="text-xs text-gray-600 dark:text-gray-400"><svg class="w-3.5 h-3.5 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>@u.MerchantName</p>
                                    }
                                    @if (!string.IsNullOrEmpty(u.BranchName))
                                    {
                                        <p class="text-xs text-gray-500 dark:text-gray-500"><svg class="w-3.5 h-3.5 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>@u.BranchName</p>
                                    }
                                </div>
                            }
                            @if (u.Role == "Admin")
                            { <span class="badge bg-purple-100 text-purple-700">@u.Role</span> }
                            else if (u.Role == "MerchantAdmin")
                            { <span class="badge badge-info">Merchant Admin</span> }
                            else
                            { <span class="badge bg-gray-100 dark:bg-border/30 text-gray-700 dark:text-gray-300">@u.Role</span> }
                        </div>
                        <div class="flex gap-2 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
                            <button class="btn-secondary flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowEditModal(u)">Edit</button>
                            <button class="btn-danger flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowRevokeConfirm(u.Id, u.FullName ?? u.Username)">Revoke</button>
                        </div>
                    </div>
                }
            </div>
        }
        </div>
        @if (!IsLoading && TotalRecords > 0)
        {
            <div class="mt-6 border-t border-gray-100 dark:border-gray-800 pt-6">
                <Pagination CurrentPage="CurrentPage"
                            TotalPages="TotalPages"
                            TotalRecords="TotalRecords"
                            PageSize="PageSize"
                            OnPageChanged="HandlePageChanged" />
            </div>
        }
    </div>

</div>

@if (ShowModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md flex flex-col max-h-[90vh]">
            <form @onsubmit="SaveUser" @onsubmit:preventDefault="true" class="flex flex-col overflow-hidden flex-1">
                <!-- Dummy inputs to thwart browser autofill -->
                <input type="text" style="display:none" autocomplete="username" />
                <input type="password" style="display:none" autocomplete="current-password" />
                
                <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between shrink-0">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">@(IsEditMode ? "Edit User" : "Create New User")</h3>
                    <button type="button" @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                
                <div class="overflow-y-auto flex-1 p-6 space-y-4">
                    @if (!IsEditMode)
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
                            <input type="text" class="form-input w-full" @bind="CreateRequest.Username" required placeholder="johndoe" autocomplete="off" />
                        </div>
                    }
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Full Name</label>
                        @if (IsEditMode)
                        {
                            <input type="text" class="form-input w-full" @bind="UpdateRequest.FullName" required placeholder="John Doe" autocomplete="off" />
                        }
                        else
                        {
                            <input type="text" class="form-input w-full" @bind="CreateRequest.FullName" required placeholder="John Doe" autocomplete="off" />
                        }
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email Address</label>
                        @if (IsEditMode)
                        {
                            <input type="email" class="form-input w-full" @bind="UpdateRequest.Email" required placeholder="user@example.com" autocomplete="off" />
                        }
                        else
                        {
                            <input type="email" class="form-input w-full" @bind="CreateRequest.Email" required placeholder="user@example.com" autocomplete="off" />
                        }
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Phone Number</label>
                        @if (IsEditMode)
                        {
                            <input type="text" class="form-input w-full" @bind="UpdateRequest.PhoneNumber" placeholder="+123456789" autocomplete="off" />
                        }
                        else
                        {
                            <input type="text" class="form-input w-full" @bind="CreateRequest.PhoneNumber" placeholder="+123456789" autocomplete="off" />
                        }
                    </div>
                    @if (!IsEditMode)
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
                            <input type="password" class="form-input w-full" @bind="CreateRequest.PlainPassword" required placeholder="••••••••" autocomplete="new-password" />
                        </div>
                    }
                    else
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Password (leave blank to keep current)</label>
                            <input type="password" class="form-input w-full" @bind="UpdateRequest.PlainPassword" placeholder="••••••••" autocomplete="new-password" />
                        </div>
                    }
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Role</label>
                        <select class="form-input w-full" @bind="SelectedRole">
                            @foreach (var role in AvailableRoles)
                            {
                                <option value="@role">@GetRoleLabel(role)</option>
                            }
                        </select>
                    </div>
                    @if (CallerRole == "Admin" && (SelectedRole == UserRole.MerchantAdmin || SelectedRole == UserRole.Staff))
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assigned Merchant</label>
                            <select class="form-input w-full" value="@GetSelectedMerchantId()" @onchange="OnMerchantChanged">
                                <option value="">— Select a Merchant —</option>
                                @foreach (var merchant in MerchantList)
                                {
                                    <option value="@merchant.Id">@merchant.Name</option>
                                }
                            </select>
                        </div>
                    }
                    @if (SelectedRole == UserRole.Staff && (CallerRole == "MerchantAdmin" || (CallerRole == "Admin" && BranchList.Any())))
                    {
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assigned Branch</label>
                            <select class="form-input w-full" value="@GetSelectedBranchId()" @onchange="OnBranchChanged">
                                <option value="">— Select a Branch —</option>
                                @foreach (var branch in BranchList)
                                {
                                    <option value="@branch.Id">@branch.Name</option>
                                }
                            </select>
                        </div>
                    }
                    @if (IsEditMode)
                    {
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="isActive" class="rounded border-gray-300 text-accent focus:ring-accent" @bind="UpdateRequest.IsActive" />
                            <label for="isActive" class="text-sm font-medium text-gray-700 dark:text-gray-300">Is Active</label>
                        </div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="mx-6 mb-2 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl flex items-start gap-2">
                        <svg class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /></svg>
                        <span class="text-red-700 dark:text-red-400 text-sm flex-1">@ErrorMessage</span>
                        <button type="button" class="text-red-400 hover:text-red-600 font-bold leading-none" @onclick="@(() => ErrorMessage = "")">✕</button>
                    </div>
                }
                <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3 shrink-0">
                    <button type="button" @onclick="CloseModal" class="btn-ghost">Cancel</button>
                    <button type="submit" class="btn-primary" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></div>
                        }
                        @(IsEditMode ? "Save Changes" : "Create User")
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@if (ShowRevokeModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[60] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-red-100 dark:border-red-900/30 bg-red-50 dark:bg-red-900/10 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /></svg>
                </div>
                <h3 class="text-base font-bold text-red-700 dark:text-red-400">Revoke Access</h3>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-700 dark:text-gray-300">
                    Are you sure you want to revoke access for <span class="font-semibold">@RevokeTargetName</span>? This will remove their ability to log in.
                </p>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseRevokeModal" class="btn-ghost">Cancel</button>
                <button @onclick="ConfirmRevoke" class="btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                    Yes, Revoke
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserResponseDto> UserList = new();
    private List<BranchResponseDto> BranchList = new();
    private List<MerchantResponseDto> MerchantList = new();
    private CreateUserRequest CreateRequest = new();
    private UpdateUserRequest UpdateRequest = new();
    private Guid? EditingId;
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool ShowModal = false;
    private bool IsEditMode = false;
    private bool ShowRevokeModal = false;
    private Guid? RevokeTargetId;
    private string RevokeTargetName = "";
    private string ErrorMessage = "";
    private string _searchTerm = "";
    private bool _isSearching = false;
    private bool isGridView = true;
    private CancellationTokenSource? _searchCts;

    // Caller's role and context
    private string CallerRole = "";
    private Guid? CallerMerchantId;
    private Guid? CallerBranchId;

    // Available roles based on caller's role
    private IEnumerable<UserRole> AvailableRoles => CallerRole switch
    {
        "Admin" => Enum.GetValues<UserRole>(),
        "MerchantAdmin" => new[] { UserRole.MerchantAdmin, UserRole.Staff, UserRole.Customer },
        _ => new[] { UserRole.Customer }   // Staff can only create Customer
    };

    private static string GetRoleLabel(UserRole role) => role switch
    {
        UserRole.MerchantAdmin => "Merchant Admin",
        _ => role.ToString()
    };

    // Pagination
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int TotalRecords = 0;
    private int PageSize = 10;

    // Helper to handle role selection binding
    private UserRole SelectedRole
    {
        get => IsEditMode ? (UpdateRequest.Role ?? UserRole.Staff) : CreateRequest.Role;
        set
        {
            if (IsEditMode) UpdateRequest.Role = value;
            else CreateRequest.Role = value;

            // When Admin switches role away from Staff, clear branch list
            if (CallerRole == "Admin" && value != UserRole.Staff)
            {
                BranchList = new();
                if (IsEditMode) UpdateRequest.BranchId = null;
                else CreateRequest.BranchId = null;
            }
        }
    }



    private string GetSelectedBranchId() => IsEditMode ? UpdateRequest.BranchId?.ToString() ?? "" : CreateRequest.BranchId?.ToString() ?? "";
    
    private void OnBranchChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        var guid = Guid.TryParse(val, out var g) ? (Guid?)g : null;
        if (IsEditMode) UpdateRequest.BranchId = guid;
        else CreateRequest.BranchId = guid;
    }

    private string GetSelectedMerchantId() => IsEditMode ? UpdateRequest.MerchantId?.ToString() ?? "" : CreateRequest.MerchantId?.ToString() ?? "";
    
    private async Task OnMerchantChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        var guid = Guid.TryParse(val, out var g) ? (Guid?)g : null;
        if (IsEditMode) UpdateRequest.MerchantId = guid;
        else CreateRequest.MerchantId = guid;

        // For Admin creating Staff: load branches for selected merchant
        if (CallerRole == "Admin" && SelectedRole == UserRole.Staff && guid.HasValue)
        {
            BranchList = new();
            if (IsEditMode) UpdateRequest.BranchId = null;
            else CreateRequest.BranchId = null;

            var branchResp = await BranchService.GetBranchesByMerchantIdAsync(guid.Value, new PaginationFilter { PageSize = 200 });
            if (branchResp.IsSuccess && branchResp.Data?.Data != null)
            {
                BranchList = branchResp.Data.Data.ToList();
            }
        }
        else if (CallerRole == "Admin" && SelectedRole != UserRole.Staff)
        {
            // Clear branch when not Staff
            BranchList = new();
            if (IsEditMode) UpdateRequest.BranchId = null;
            else CreateRequest.BranchId = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        CallerRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                     ?? user.FindFirst("role")?.Value
                     ?? "";

        var merchantClaim = user.FindFirst("MerchantId")?.Value ?? user.FindFirst("merchantId")?.Value;
        if (Guid.TryParse(merchantClaim, out var mId)) CallerMerchantId = mId;

        var branchClaim = user.FindFirst("BranchId")?.Value ?? user.FindFirst("branchId")?.Value;
        if (Guid.TryParse(branchClaim, out var bId)) CallerBranchId = bId;

        if (CallerRole == "MerchantAdmin")
        {
            var branchResp = await BranchService.GetAllBranchesAsync(new PaginationFilter { PageSize = 100 });
            if (branchResp.IsSuccess && branchResp.Data?.Data != null)
            {
                BranchList = branchResp.Data.Data.ToList();
            }
        }
        else if (CallerRole == "Admin")
        {
            var merchantResp = await MerchantService.GetAllMerchantsAsync(new PaginationFilter { PageSize = 100 });
            if (merchantResp.IsSuccess && merchantResp.Data?.Data != null)
            {
                MerchantList = merchantResp.Data.Data.ToList();
            }
        }

        await LoadUsers();
    }

    private async Task HandlePageChanged(int newPage)
    {
        CurrentPage = newPage;
        await LoadUsers();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            CurrentPage = 1;
            await LoadUsers(isSearching: true);
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task LoadUsers(bool isSearching = false)
    {
        if (!isSearching) IsLoading = true;
        _isSearching = isSearching;
        ErrorMessage = "";
        try
        {
            var filter = new PaginationFilter 
            { 
                PageNumber = CurrentPage, 
                PageSize = PageSize,
                SearchTerm = _searchTerm
            };
            var response = await UserService.GetAllUsersAsync(filter);
            if (response.IsSuccess && response.Data != null)
            {
                var data = response.Data.Data;
                if (CallerRole == "Staff")
                {
                    data = data.Where(u => u.Role != "Admin" && u.Role != "MerchantAdmin").ToList();
                }
                UserList = data.ToList();
                TotalPages = response.Data.TotalPages;
                TotalRecords = response.Data.TotalRecords;
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to load users: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ShowInviteModal()
    {
        ErrorMessage = "";
        IsEditMode = false;
        
        // Determine default role
        UserRole defaultRole = CallerRole switch
        {
            "Admin" => UserRole.Admin,
            "MerchantAdmin" => UserRole.Staff,
            _ => UserRole.Customer
        };

        CreateRequest = new CreateUserRequest 
        { 
            Role = defaultRole,
            MerchantId = CallerMerchantId,
            BranchId = CallerBranchId
        };
        ShowModal = true;
    }

    private void ShowEditModal(UserResponseDto user)
    {
        ErrorMessage = "";
        IsEditMode = true;
        EditingId = user.Id;
        UpdateRequest = new UpdateUserRequest
        {
            Email = user.Email,
            FullName = user.FullName,
            PhoneNumber = user.PhoneNumber,
            IsActive = user.IsActive,
            BranchId = user.BranchId,
            Role = Enum.TryParse<UserRole>(user.Role, out var role) ? role : UserRole.Staff
        };
        ShowModal = true;
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private async Task SaveUser()
    {
        ErrorMessage = "";
        IsSaving = true;
        try
        {
            bool isSuccess;
            string message = "";
            if (IsEditMode && EditingId.HasValue)
            {
                var response = await UserService.UpdateUserAsync(EditingId.Value, UpdateRequest);
                isSuccess = response.IsSuccess;
                message = response.Message;
            }
            else
            {
                var response = await UserService.CreateUserAsync(CreateRequest);
                isSuccess = response.IsSuccess;
                message = response.Message;
            }

            if (isSuccess)
            {
                ShowModal = false;
                await LoadUsers();
            }
            else
            {
                ErrorMessage = message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ShowRevokeConfirm(Guid id, string name)
    {
        RevokeTargetId = id;
        RevokeTargetName = name;
        ShowRevokeModal = true;
    }

    private void CloseRevokeModal()
    {
        ShowRevokeModal = false;
        RevokeTargetId = null;
    }

    private async Task ConfirmRevoke()
    {
        if (!RevokeTargetId.HasValue) return;
        ShowRevokeModal = false;
        ErrorMessage = "";
        var response = await UserService.DeleteUserAsync(RevokeTargetId.Value);
        RevokeTargetId = null;
        if (response.IsSuccess)
        {
            await LoadUsers();
        }
        else
        {
            ErrorMessage = response.Message;
        }
    }
}
