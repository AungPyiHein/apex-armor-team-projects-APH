@page "/customers"
@layout MainLayout
@using POS.Frontend.Services.Sales
@using POS.Frontend.Models.Sales
@using POS.Shared.Models
@using POS.Frontend.Services.Merchants
@using POS.Frontend.Models.Merchants
@inject ICustomerService CustomerService
@inject IMerchantService MerchantService
@inject ISaleService SaleService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Customers</h2>
            <p class="page-subtitle">Manage your customer list</p>
        </div>
        <button class="btn-primary" @onclick="ShowAddModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Customer
        </button>
    </div>

    <div class="card">
        <div class="card-header shrink-0">
            <div class="flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between w-full">
                <div class="flex gap-3 flex-wrap items-center">
                    <div class="relative">
                        <input type="text" placeholder="Search customers…" class="form-input max-w-xs pl-9" 
                               @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        @if (IsSearching)
                        {
                            <div class="absolute right-3 top-2.5 w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                        }
                    </div>
                    <span class="text-xs text-muted">@TotalRecords total</span>

                    @if (UserRole == "Admin")
                    {
                        <div class="h-8 w-px bg-gray-200 dark:bg-gray-700 mx-2 hidden sm:block"></div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-medium text-gray-500">Merchant:</span>
                            <select class="form-input py-1 text-xs min-w-[150px]" @bind="SelectedMerchantId">
                                <option value="@Guid.Empty">All Merchants</option>
                                @foreach (var m in MerchantList)
                                {
                                    <option value="@m.Id">@m.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>

                <!-- View Toggle -->
                <div class="flex bg-gray-100 dark:bg-gray-800 p-1 rounded-lg shrink-0">
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(!isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = false">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
                        List
                    </button>
                    <button class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors @(isGridView ? "bg-white dark:bg-surface text-accent shadow-sm" : "text-gray-500 hover:text-gray-700")"
                            @onclick="() => isGridView = true">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                        Grid
                    </button>
                </div>
            </div>
        </div>
        <div class="flex-1 overflow-y-auto px-4 sm:px-6 py-4">
        @if (!isGridView)
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        @if (UserRole == "Admin")
                        {
                            <th>Merchant</th>
                        }
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Total Spent</th>
                        <th>Recently Bought</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="relative">
                    @if (IsLoading && !IsSearching)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10">
                                <div class="flex justify-center">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10 text-red-500">
                                @ErrorMessage
                                <button class="btn-secondary ml-2" @onclick="() => LoadCustomers()">Retry</button>
                            </td>
                        </tr>
                    }
                    else if (!CustomerList.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-10 text-muted italic">No customers found</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in CustomerList)
                        {
                            var customerOrders = OrderList.Where(o => o.CustomerId == c.Id).ToList();
                            var totalSpent = customerOrders.Sum(o => o.TotalAmount);
                            var recentlyBought = string.Join(", ", customerOrders.SelectMany(o => o.Items).Select(i => i.ProductName).Distinct().Take(3));
                            if (string.IsNullOrEmpty(recentlyBought))
                            {
                                recentlyBought = "-";
                            }
                            else if (customerOrders.SelectMany(o => o.Items).Select(i => i.ProductName).Distinct().Count() > 3)
                            {
                                recentlyBought += "...";
                            }

                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
                                            <span class="text-accent text-xs font-semibold">@c.Name[0]</span>
                                        </div>
                                        <span class="font-medium text-gray-800 dark:text-gray-200">@c.Name</span>
                                    </div>
                                </td>
                                @if (UserRole == "Admin")
                                {
                                    <td>
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300">
                                            @c.MerchantName
                                        </span>
                                    </td>
                                }
                                <td class="text-muted">@c.PhoneNumber</td>
                                <td class="text-muted">@c.Email</td>
                                <td class="font-semibold text-accent">@totalSpent.ToString("N0") MMK</td>
                                <td class="text-muted text-xs truncate max-w-[150px]" title="@recentlyBought">@recentlyBought</td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => ShowEditModal(c)">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => ShowDeleteConfirm(c.Id, c.Name)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                @foreach (var c in CustomerList)
                {
                    var customerOrders = OrderList.Where(o => o.CustomerId == c.Id).ToList();
                    var totalSpent = customerOrders.Sum(o => o.TotalAmount);
                    var recentlyBought = string.Join(", ", customerOrders.SelectMany(o => o.Items).Select(i => i.ProductName).Distinct().Take(3));
                    if (string.IsNullOrEmpty(recentlyBought))
                    {
                        recentlyBought = "-";
                    }
                    else if (customerOrders.SelectMany(o => o.Items).Select(i => i.ProductName).Distinct().Count() > 3)
                    {
                        recentlyBought += "...";
                    }
                    
                    <div class="group bg-white dark:bg-surface border border-gray-100 dark:border-gray-800 rounded-2xl p-4 hover:shadow-xl hover:border-accent/20 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-xl text-accent group-hover:bg-accent group-hover:text-white transition-colors">
                                <span class="font-bold">@c.Name[0]</span>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between mb-1">
                                <h4 class="font-bold text-gray-900 dark:text-gray-100 text-lg truncate">@c.Name</h4>
                                @if (UserRole == "Admin")
                                {
                                    <span class="px-1.5 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-[10px] rounded font-medium">@c.MerchantName</span>
                                }
                            </div>
                            <p class="text-sm text-gray-400 truncate"><svg class="w-3.5 h-3.5 inline-block mr-1 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>@c.PhoneNumber</p>
                            <p class="text-sm text-gray-400 mb-3 truncate"><svg class="w-3.5 h-3.5 inline-block mr-1 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>@c.Email</p>
                            <div class="bg-gray-50 dark:bg-gray-800/50 p-3 rounded-xl border border-gray-100 dark:border-gray-800 mb-2">
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Total Spent</p>
                                <p class="font-semibold text-accent">@totalSpent.ToString("N0") MMK</p>
                            </div>
                            <p class="text-xs text-muted truncate" title="@recentlyBought">Purchases: @recentlyBought</p>
                        </div>
                        <div class="flex gap-2 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
                            <button class="btn-secondary flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowEditModal(c)">Edit</button>
                            <button class="btn-danger flex-1 py-1.5 text-xs justify-center" @onclick="() => ShowDeleteConfirm(c.Id, c.Name)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        }
        </div>
        @if (!IsLoading && TotalRecords > 0)
        {
            <div class="mt-6 border-t border-gray-100 dark:border-gray-800 pt-6">
                <Pagination CurrentPage="CurrentPage"
                            TotalPages="TotalPages"
                            TotalRecords="TotalRecords"
                            PageSize="PageSize"
                            OnPageChanged="HandlePageChanged" />
            </div>
        }
    </div>

</div>

@if (ShowModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">@(IsEditMode ? "Edit Customer" : "Add New Customer")</h3>
                <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Full Name</label>
                    <input type="text" class="form-input w-full" @bind="CurrentCustomer.Name" placeholder="Enter customer name" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Phone Number</label>
                    <input type="text" class="form-input w-full" @bind="CurrentCustomer.PhoneNumber" placeholder="e.g. +1 555-0101" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email Address</label>
                    <input type="email" class="form-input w-full" @bind="CurrentCustomer.Email" placeholder="customer@example.com" />
                </div>
                @if (UserRole == "Admin" && !IsEditMode)
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assigned Merchant</label>
                        <select class="form-input w-full" @bind="CurrentCustomer.MerchantId">
                            <option value="">-- Select Merchant --</option>
                            @foreach (var m in MerchantList)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                }
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface flex justify-end gap-3">
                <button @onclick="CloseModal" class="btn-ghost">Cancel</button>
                <button @onclick="SaveCustomer" class="btn-primary" disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></div>
                    }
                    @(IsEditMode ? "Save Changes" : "Create Customer")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowDeleteConfirmModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[55] flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-red-100 dark:border-red-900/30 bg-red-50 dark:bg-red-900/10 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                </div>
                <h3 class="text-base font-bold text-red-700 dark:text-red-400">Delete Customer</h3>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-700 dark:text-gray-300">
                    Are you sure you want to delete <span class="font-semibold">@DeleteConfirmName</span>? Their purchase history will also be removed.
                </p>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 dark:border-gray-800 flex justify-end gap-3">
                <button @onclick="CloseDeleteConfirmModal" class="btn-ghost">Cancel</button>
                <button @onclick="ConfirmDeleteCustomer" class="btn-danger flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<CustomerResponseDto> CustomerList = new();
    private List<OrderResponseDto> OrderList = new();
    private CreateCustomerRequest CurrentCustomer = new();
    private Guid? EditingId;
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool ShowModal = false;
    private bool IsEditMode = false;
    private bool ShowDeleteConfirmModal = false;
    private Guid DeleteConfirmId;
    private string DeleteConfirmName = "";
    private string ErrorMessage = "";
    private string SearchTerm = "";
    private bool IsSearching = false;
    private bool isGridView = true;
    private CancellationTokenSource? _searchCts;
    private int TotalRecords = 0;
    
    // Pagination
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int PageSize = 10;

    // TODO: Get this from Auth state
    private Guid MerchantId = Guid.Empty; 
    private string UserRole = "";
    private List<MerchantResponseDto> MerchantList = new();

    private Guid SelectedMerchantId
    {
        get => MerchantId;
        set
        {
            if (MerchantId != value)
            {
                MerchantId = value;
                _ = LoadCustomers();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var merchantClaim = user.FindFirst("MerchantId")?.Value ?? user.FindFirst("merchantId")?.Value;
            var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? user.FindFirst("role")?.Value ?? "";

            // Always set UserRole from claims first
            UserRole = role;

            if (role == "Admin")
            {
                MerchantId = Guid.Empty; // All merchants by default for Admin
                
                var merchantsResponse = await MerchantService.GetAllMerchantsAsync(new PaginationFilter { PageSize = 100 });
                if (merchantsResponse.IsSuccess && merchantsResponse.Data?.Data != null)
                {
                    MerchantList = merchantsResponse.Data.Data.ToList();
                }
                
                await LoadCustomers();
            }
            else if (!string.IsNullOrEmpty(merchantClaim) && Guid.TryParse(merchantClaim, out var mId))
            {
                MerchantId = mId;
                await LoadCustomers();
            }
            else
            {
                ErrorMessage = "Unauthorized or missing merchant assignment.";
                IsLoading = false;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to initialize: " + ex.Message;
            IsLoading = false;
        }
    }

    private async Task HandlePageChanged(int newPage)
    {
        CurrentPage = newPage;
        await LoadCustomers();
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            CurrentPage = 1;
            await LoadCustomers(isSearching: true);
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task LoadCustomers(bool isSearching = false)
    {
        if (!isSearching) IsLoading = true;
        IsSearching = isSearching;
        ErrorMessage = "";
        try
        {
            var filter = new PaginationFilter { PageNumber = CurrentPage, PageSize = PageSize, SearchTerm = SearchTerm };
            
            var ordersTask = SaleService.GetAllOrdersAsync(new PaginationFilter { PageSize = 1000 });
            var customersTask = CustomerService.GetCustomersAsync(MerchantId == Guid.Empty ? null : MerchantId, filter);
            await Task.WhenAll(ordersTask, customersTask);
            
            var response = customersTask.Result;
            var ordersRes = ordersTask.Result;
            
            if (ordersRes?.IsSuccess == true && ordersRes.Data != null)
            {
                OrderList = ordersRes.Data.Data.ToList();
            }

            if (response.IsSuccess && response.Data != null)
            {
                CustomerList = response.Data.Data.ToList();
                TotalRecords = response.Data.TotalRecords;
                TotalPages = response.Data.TotalPages;
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to load customers: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
            IsSearching = false;
        }
    }

    private void HandleSearch()
    {
        // This old method is replaced by the KeyboardEventArgs one
    }

    private void ShowAddModal()
    {
        IsEditMode = false;
        CurrentCustomer = new CreateCustomerRequest { MerchantId = MerchantId };
        ShowModal = true;
    }

    private void ShowEditModal(CustomerResponseDto customer)
    {
        IsEditMode = true;
        EditingId = customer.Id;
        CurrentCustomer = new CreateCustomerRequest
        {
            MerchantId = MerchantId,
            Name = customer.Name,
            PhoneNumber = customer.PhoneNumber,
            Email = customer.Email
        };
        ShowModal = true;
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private async Task SaveCustomer()
    {
        if (string.IsNullOrWhiteSpace(CurrentCustomer.Name)) return;

        IsSaving = true;
        try
        {
            bool isSuccess;
            if (IsEditMode && EditingId.HasValue)
            {
                var response = await CustomerService.UpdateCustomerAsync(EditingId.Value, CurrentCustomer);
                isSuccess = response.IsSuccess;
            }
            else
            {
                var response = await CustomerService.CreateCustomerAsync(CurrentCustomer);
                isSuccess = response.IsSuccess;
            }

            if (isSuccess)
            {
                ShowModal = false;
                await LoadCustomers();
            }
            else
            {
                // Handle error (maybe show an alert)
            }
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void ShowDeleteConfirm(Guid id, string name)
    {
        DeleteConfirmId = id;
        DeleteConfirmName = name;
        ShowDeleteConfirmModal = true;
    }

    private void CloseDeleteConfirmModal()
    {
        ShowDeleteConfirmModal = false;
    }

    private async Task ConfirmDeleteCustomer()
    {
        ShowDeleteConfirmModal = false;
        await DeleteCustomer(DeleteConfirmId);
    }

    private async Task DeleteCustomer(Guid id)
    {
        var response = await CustomerService.DeleteCustomerAsync(id);
        if (response.IsSuccess)
        {
            await LoadCustomers();
        }
    }
}
