@page "/sales/terminal"
@layout MainLayout
@using POS.Frontend.Models.Products
@using POS.Frontend.Models.Categories
@using POS.Frontend.Models.Sales
@using POS.Frontend.Models.Merchants
@using POS.Frontend.Models.Inventory
@using POS.Shared.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject ISaleService SaleService
@inject IBranchService BranchService
@inject ICustomerService CustomerService
@inject IMerchantService MerchantService
@inject POS.Frontend.Services.Inventory.IInventoryService InventoryService
@inject AuthenticationStateProvider AuthStateProvider

<div class="flex gap-4 h-[calc(100vh-7.5rem)]">

    <!-- LEFT: Product browser -->
    <div class="flex flex-col flex-1 gap-4 min-w-0">

        <!-- Search + category filter -->
        <div class="flex gap-3">
            <div class="relative flex-1">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                <input type="text" placeholder="Search products…" class="form-input pl-9" 
                       @bind="SearchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
                @if (isSearching)
                {
                    <div class="absolute right-3 top-1/2 -translate-y-1/2">
                        <div class="w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                    </div>
                }
            </div>
            <select class="form-input w-48 text-xs" value="@selectedBranchId" @onchange="HandleBranchChange">
                <option value="">— Select Branch —</option>
                @foreach (var br in BranchList)
                {
                    <option value="@br.Id">
                        @br.Name @(IsStaff && br.Id == staffBranchId ? "(My Branch)" : "")
                    </option>
                }
            </select>
            <select class="form-input w-40 text-xs" value="@SelectedCategoryIdString" @onchange="HandleCategoryChange">
                <option value="">All Categories</option>
                @foreach (var cat in CategoryList)
                {
                    <option value="@cat.Id.ToString()">@cat.Name</option>
                }
            </select>
        </div>

        <!-- Product grid -->
        <div class="flex-1 overflow-y-auto">
            @if (isLoading && !isSearching)
            {
                <div class="flex items-center justify-center h-full">
                    <div class="flex flex-col items-center gap-2">
                        <svg class="animate-spin h-8 w-8 text-accent" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        <p class="text-sm text-muted">Loading products...</p>
                    </div>
                </div>
            }
            else if (!ProductList.Any())
            {
                <div class="flex flex-col items-center justify-center h-full text-center">
                    <p class="text-sm text-muted">No products found</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                    @foreach (var p in ProductList)
                    {
                        var stock = BranchInventory.FirstOrDefault(i => i.ProductId == p.Id)?.StockQuantity ?? 0;
                        var outOfStock = stock <= 0;
                        var cannotSell = !CanSell;
                        var isDisabled = outOfStock || cannotSell;
                        <button class="relative bg-white dark:bg-surface rounded-xl border border-border p-3 text-left hover:border-accent hover:shadow-card-hover transition-all group @(isDisabled ? "opacity-50 cursor-not-allowed" : "")"
                                disabled="@isDisabled"
                                @onclick="() => AddToCart(p, stock)">
                            @if (cannotSell)
                            {
                                <div class="absolute top-0 right-0 bg-yellow-500 text-white text-[10px] font-bold px-2 py-1 rounded-bl-xl rounded-tr-xl z-10">
                                    VIEW ONLY
                                </div>
                            }
                            else if (outOfStock)
                            {
                                <div class="absolute top-0 right-0 bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-bl-xl rounded-tr-xl z-10">
                                    OUT OF STOCK
                                </div>
                            }
                            <div class="w-full h-16 rounded-lg bg-gray-50 dark:bg-surface flex items-center justify-center text-2xl mb-2 group-hover:bg-indigo-50 transition-colors">
                                @CategoryIconHelper.GetIcon(p.CategoryName)
                            </div>
                            <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 truncate">@p.Name</p>
                            <p class="text-xs text-muted">@p.CategoryName</p>
                            <div class="flex justify-between items-end mt-1">
                                <p class="text-sm font-bold text-accent">@p.Price.ToString("N0") MMK</p>
                                @if (!outOfStock)
                                {
                                    <p class="text-[10px] text-gray-500 font-medium">@stock in stock</p>
                                }
                            </div>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <!-- RIGHT: Cart / Receipt -->
    <div class="w-80 shrink-0 flex flex-col bg-white dark:bg-surface rounded-2xl border border-border shadow-card overflow-hidden">

        <!-- Cart header -->
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
            <p class="font-semibold text-gray-900 dark:text-gray-100 text-sm">Current Order</p>
            <button class="text-xs text-red-500 hover:underline" @onclick="ClearCart">Clear</button>
        </div>

        <!-- Cart items -->
        <div class="flex-1 overflow-y-auto divide-y divide-border/60">
            @if (!CartItems.Any())
            {
                <div class="flex flex-col items-center justify-center h-full py-12 text-center">
                    <div class="w-12 h-12 rounded-full bg-gray-50 dark:bg-surface flex items-center justify-center mb-3">
                        <svg class="w-5 h-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4" /></svg>
                    </div>
                    <p class="text-sm text-muted">Cart is empty</p>
                    <p class="text-xs text-gray-400 mt-1">Tap a product to add it</p>
                </div>
            }
            else
            {
                @foreach (var item in CartItems)
                {
                    <div class="flex items-center gap-3 px-4 py-3">
                        <span class="text-lg">@item.Icon</span>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-medium text-gray-800 dark:text-gray-200 truncate">@item.Name</p>
                            <p class="text-xs text-accent font-semibold">@item.Price.ToString("N0") MMK</p>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <button class="w-5 h-5 rounded-md bg-gray-100 dark:bg-border/30 text-gray-600 dark:text-gray-400 text-xs font-bold flex items-center justify-center hover:bg-gray-200"
                                    @onclick="() => ChangeQty(item, -1)">−</button>
                            <input type="number" 
                                   class="w-10 h-6 rounded bg-white text-gray-900 dark:bg-gray-700 dark:text-white text-xs font-semibold text-center border border-gray-300 dark:border-gray-600 focus:border-accent outline-none transition-colors" 
                                   value="@item.Qty" 
                                   @onchange="@((ChangeEventArgs e) => HandleQtyInputChange(item, e))" />
                            <button class="w-5 h-5 rounded-md bg-accent/10 text-accent text-xs font-bold flex items-center justify-center hover:bg-accent/20"
                                    @onclick="() => ChangeQty(item, 1)">+</button>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Totals -->
        <div class="px-5 py-4 border-t border-border space-y-2">
            <div class="flex justify-between text-xs text-muted">
                <span>Subtotal</span><span>@Subtotal.ToString("N0") MMK</span>
            </div>
            <div class="flex justify-between text-xs text-muted">
                <span>Tax (5%)</span><span>@Tax.ToString("N0") MMK</span>
            </div>
            <div class="flex justify-between text-sm font-bold text-gray-900 dark:text-gray-100 pt-2 border-t border-border">
                <span>Total</span><span>@Total.ToString("N0") MMK</span>
            </div>
            @if (selectedCustomerId.HasValue && selectedCustomerId.Value != Guid.Empty && CartItems.Any() && applyLoyalty)
            {
                <div class="flex justify-between text-xs font-semibold text-indigo-600 dark:text-indigo-400 pt-1">
                    <span>Points to earn</span><span>+@CalculateEarnedPoints().ToString("N0")</span>
                </div>
            }
        </div>

        <!-- Loyalty Toggle -->
        @if (selectedCustomerId.HasValue && selectedCustomerId.Value != Guid.Empty)
        {
            <div class="px-5 pb-2 flex items-center justify-between">
                <div class="flex flex-col">
                    <span class="text-xs font-semibold text-gray-700 dark:text-gray-300">Apply Loyalty Points</span>
                    <span class="text-[10px] text-gray-400">@(applyLoyalty ? $"Earns +{CalculateEarnedPoints():N0} pts" : "Skipped for this sale")</span>
                </div>
                <button class="relative w-10 h-5 rounded-full transition-colors duration-200 focus:outline-none
                              @(applyLoyalty ? "bg-accent" : "bg-gray-300 dark:bg-gray-600")"
                        @onclick="() => applyLoyalty = !applyLoyalty">
                    <span class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform duration-200
                                @(applyLoyalty ? "translate-x-5" : "translate-x-0")"></span>
                </button>
            </div>
        }

        <!-- Customer select -->
        <div class="px-5 pb-3">
            <select class="form-input text-xs" value="@selectedCustomerId" @onchange="HandleCustomerChange">
                <option value="">— Walk-in Customer —</option>
                @foreach (var c in CustomerList)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>

        @if (selectedCustomerId.HasValue && selectedCustomerId.Value != Guid.Empty && selectedCustomerLoyalty != null)
        {
            <div class="px-5 pb-3">
                <div class="p-3 bg-indigo-50/50 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-800/30 rounded-xl relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-16 h-16 bg-gradient-to-br from-indigo-500/10 to-purple-500/10 rounded-bl-full pointer-events-none"></div>
                    <div class="flex justify-between items-start mb-1">
                        <span class="text-xs font-bold text-gray-800 dark:text-gray-200">Loyalty Account</span>
                        @if (!string.IsNullOrEmpty(selectedCustomerLoyalty.Tier))
                        {
                            <span class="px-1.5 py-0.5 bg-indigo-100 text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-300 text-[9px] font-bold uppercase tracking-wider rounded">@selectedCustomerLoyalty.Tier</span>
                        }
                    </div>
                    <div class="flex items-baseline gap-1 mt-1">
                        <span class="text-xl font-black text-indigo-600 dark:text-indigo-400">@selectedCustomerLoyalty.CurrentBalance.ToString("N0")</span>
                        <span class="text-[10px] text-gray-500 font-medium">pts available</span>
                    </div>
                </div>
            </div>

            @if (reachableNow.Any() || reachableAfterSale.Any())
            {
                <div class="px-5 pb-3 space-y-2">
                    @if (reachableNow.Any())
                    {
                        <div class="rounded-xl overflow-hidden shadow-md shadow-purple-200/60 dark:shadow-purple-900/20">
                            <div class="bg-gradient-to-r from-violet-600 to-purple-700 px-3 py-2 flex items-center gap-1.5">
                                <span class="text-sm">🎁</span>
                                <p class="text-[11px] font-extrabold text-white uppercase tracking-widest flex-1">Rewards Available</p>
                                <span class="text-[10px] bg-white/20 text-white font-bold px-1.5 py-0.5 rounded-full">@reachableNow.Count</span>
                            </div>
                            <div class="bg-white dark:bg-surface divide-y divide-purple-100 dark:divide-purple-900/30">
                                @foreach (var reward in reachableNow)
                                {
                                    var rName = reward.Name.Contains(": ") ? reward.Name.Split(": ", 2)[1] : reward.Name;
                                    var rState = GetPosClaimState(reward.Id);
                                    var rIsPending = rState == PosClaimState.Pending;
                                    var rIsSuccess = rState == PosClaimState.Success;
                                    <div class="flex items-center gap-2 px-3 py-2">
                                        <div class="flex-1 min-w-0">
                                            <p class="text-[11px] font-bold text-gray-800 dark:text-gray-200 truncate">@rName</p>
                                            <p class="text-[10px] text-purple-500 font-semibold">@reward.PointCost.ToString("N0") pts</p>
                                        </div>
                                        @if (rIsSuccess)
                                        {
                                            <span class="flex items-center gap-1 text-[10px] font-bold text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30 px-2 py-1 rounded-lg whitespace-nowrap">
                                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                                                Claimed!
                                            </span>
                                        }
                                        else if (rIsPending)
                                        {
                                            <span class="flex items-center gap-1 text-[10px] font-bold text-yellow-700 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/30 px-2 py-1 rounded-lg whitespace-nowrap">
                                                <div class="w-2.5 h-2.5 border-2 border-yellow-400/40 border-t-yellow-600 rounded-full animate-spin"></div>
                                                Pending
                                            </span>
                                        }
                                        else
                                        {
                                            var cartNotEmpty = CartItems.Any();
                                            <button class="text-[10px] font-bold px-2.5 py-1.5 rounded-lg transition-all whitespace-nowrap shadow-sm
                                                        @(cartNotEmpty ? "bg-gray-300 dark:bg-gray-600 text-gray-500 cursor-not-allowed" : "bg-violet-600 hover:bg-violet-700 active:scale-95 text-white")"
                                                    disabled="@(PosIsClaiming || cartNotEmpty)"
                                                    title="@(cartNotEmpty ? "Complete checkout first" : "")"
                                                    @onclick="() => ClaimRewardFromPos(reward)">
                                                @(cartNotEmpty ? "Checkout first" : "Redeem")
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (reachableAfterSale.Any() && applyLoyalty)
                    {
                        <div class="p-2.5 bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-emerald-900/10 dark:to-teal-900/10 border border-emerald-200/50 dark:border-emerald-800/20 rounded-xl">
                            <p class="text-[10px] font-bold text-emerald-700 dark:text-emerald-400 mb-1">✨ Unlocks after this purchase</p>
                            @foreach (var r in reachableAfterSale)
                            {
                                var rn = r.Name.Contains(": ") ? r.Name.Split(": ", 2)[1] : r.Name;
                                <p class="text-[10px] text-emerald-600 dark:text-emerald-500 font-medium truncate">• @rn <span class="text-emerald-400">(@r.PointCost.ToString("N0") pts)</span></p>
                            }
                        </div>
                    }
                </div>
            }
        }

        <!-- Status Message -->
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="px-5 pb-3">
                <div class="p-2 rounded text-xs @(isError ? "bg-red-50 text-red-600" : "bg-green-50 text-green-600")">
                    @statusMessage
                </div>
            </div>
        }

        <!-- Charge button -->
        <div class="px-5 pb-5">
            <button class="w-full btn-primary justify-center py-3 text-sm font-semibold rounded-xl @(CartItems.Any() && !isProcessing ? "" : "opacity-50 cursor-not-allowed")"
                    @onclick="HandleCheckout" disabled="@(isProcessing || !CartItems.Any())">
                @if (isProcessing)
                {
                    <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    <span>Processing...</span>
                }
                else
                {
                    <span>Charge @Total.ToString("N0") MMK</span>
                }
            </button>
        </div>

    </div>
</div>

@code {
    private string SearchQuery = "";
    private Guid? selectedCategoryId;
    private bool isLoading = true;
    private bool isSearching = false;
    private CancellationTokenSource? _searchCts;
    private bool IsStaff = false;
    private Guid? staffBranchId;
    private bool CanSell => !IsStaff || selectedBranchId == staffBranchId;

    private List<ProductsResponseDto> ProductList = new();
    private List<CategoryResponseDto> CategoryList = new();
    private List<BranchResponseDto> BranchList = new();
    private List<CustomerResponseDto> CustomerList = new();
    private List<InventoryResponseDto> BranchInventory = new();
    private List<CartItem> CartItems = new();
    
    private Guid? selectedBranchId;
    private Guid? selectedCustomerId;
    private LoyaltyAccountResponse? selectedCustomerLoyalty;
    private List<LoyaltyRuleDto> LoyaltyRules = new();
    private List<LoyaltyReward> ActiveRewards = new();
    private List<LoyaltyReward> reachableNow = new();        // can claim with current balance
    private List<LoyaltyReward> reachableAfterSale = new(); // can claim after earning points this sale

    // POS reward claim state
    private enum PosClaimState { Idle, Pending, Success }
    private Dictionary<Guid, PosClaimState> PosClaimStates = new();
    private bool PosIsClaiming = false;
    private Dictionary<Guid, CancellationTokenSource> PosClaimCts = new();

    private bool isProcessing = false;
    private string statusMessage = "";
    private bool isError = false;
    private Guid? currentMerchantId;
    private string currentMerchantName = "";
    private string? currentMerchantLoyaltySystemId = null;
    private bool applyLoyalty = true;

    private class CartItem
    {
        public Guid ProductId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public int Qty { get; set; } = 1;
        public int MaxStock { get; set; } = 0;
    }

    private string SelectedCategoryIdString => selectedCategoryId?.ToString() ?? "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                   ?? user.FindFirst("role")?.Value
                   ?? "";
        IsStaff = role == "Staff";

        // If Staff, read their BranchId from claims and set it
        if (IsStaff)
        {
            var branchClaim = user.FindFirst("BranchId")?.Value
                              ?? user.FindFirst("branchId")?.Value;
            if (Guid.TryParse(branchClaim, out var staffBranch))
            {
                staffBranchId = staffBranch;
                selectedBranchId = staffBranch;
            }
        }

        var merchantClaim = user.FindFirst("MerchantId")?.Value ?? user.FindFirst("merchantId")?.Value;
        if (Guid.TryParse(merchantClaim, out var mId))
        {
            currentMerchantId = mId;
            // Load merchant name for event key derivation
            var merchantRes = await MerchantService.GetMerchantByIdAsync(mId);
            if (merchantRes?.IsSuccess == true && merchantRes.Data != null)
            {
                currentMerchantName = merchantRes.Data.Name;
                currentMerchantLoyaltySystemId = merchantRes.Data.LoyaltySystemId;
            }
        }

        // For Staff: load inventory first (from their locked branch) so products show correct stock
        if (IsStaff && selectedBranchId.HasValue)
        {
            await Task.WhenAll(
                LoadCategories(),
                LoadBranches(),
                LoadCustomers(),
                LoadInventoryForBranch(),
                LoadLoyaltyData()
            );
            await LoadProducts();
        }
        else
        {
            await Task.WhenAll(LoadCategories(), LoadProducts(), LoadBranches(), LoadCustomers(), LoadLoyaltyData());
        }
    }

    private async Task LoadLoyaltyData()
    {
        var rulesTask = CustomerService.GetLoyaltyRulesAsync();
        await Task.WhenAll(rulesTask);

        if (rulesTask.Result.IsSuccess && rulesTask.Result.Data != null)
        {
            LoyaltyRules = rulesTask.Result.Data;
        }

        ActiveRewards = new();
    }

    private async Task HandleCustomerChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        ClearPosClaimStates();
        if (Guid.TryParse(value, out var guid))
        {
            selectedCustomerId = guid;
            selectedCustomerLoyalty = null;
            ActiveRewards = new();
            reachableNow.Clear();
            reachableAfterSale.Clear();
            var loyaltyTask = CustomerService.GetCustomerLoyaltyAsync(guid);
            var rewardsTask = CustomerService.GetActiveRewardsAsync(customerId: guid);
            await Task.WhenAll(loyaltyTask, rewardsTask);

            if (loyaltyTask.Result.IsSuccess)
            {
                selectedCustomerLoyalty = loyaltyTask.Result.Data;
            }

            if (rewardsTask.Result.IsSuccess && rewardsTask.Result.Data != null)
            {
                ActiveRewards = rewardsTask.Result.Data;
            }

            if (selectedCustomerLoyalty != null)
            {
                CalculateReachableRewards();
            }
        }
        else
        {
            selectedCustomerId = null;
            selectedCustomerLoyalty = null;
            ActiveRewards = new();
            reachableNow.Clear();
            reachableAfterSale.Clear();
        }
    }

    private decimal CalculateEarnedPoints()
    {
        string eventKey;
        if (!string.IsNullOrWhiteSpace(currentMerchantLoyaltySystemId))
        {
            eventKey = "PURCHASE";
        }
        else
        {
            var safeKey = System.Text.RegularExpressions.Regex
                .Replace((currentMerchantName.Length > 0 ? currentMerchantName : "DEFAULT").ToUpperInvariant(), @"[^A-Z0-9]", "_");
            eventKey = $"{safeKey}_PURCHASE";
        }

        // Try merchant-specific rule first, then fall back to any active PURCHASE-like rule
        var rule = LoyaltyRules.FirstOrDefault(r => r.IsActive && r.EventKey == eventKey)
                ?? LoyaltyRules.FirstOrDefault(r => r.IsActive && r.EventKey.EndsWith("_PURCHASE"));
        if (rule == null) return 0;

        if (rule.CalculationType == "Ratio" && rule.Value > 0)
            return Math.Floor(Total / rule.Value);
        if (rule.CalculationType == "Fixed")
            return rule.Value;
        if (rule.CalculationType == "Multiplier")
            return Math.Floor(Total * rule.Value);

        return 0;
    }

    private void CalculateReachableRewards()
    {
        reachableNow.Clear();
        reachableAfterSale.Clear();
        if (selectedCustomerLoyalty != null)
        {
            var current = selectedCustomerLoyalty.CurrentBalance;
            var afterSale = current + (applyLoyalty ? CalculateEarnedPoints() : 0);

            // Rewards are now server-scoped by customer/merchant, avoid client-side prefix security logic.
            var merchantRewards = ActiveRewards;

            reachableNow       = merchantRewards.Where(r => r.IsActive && r.PointCost <= current).ToList();
            reachableAfterSale = merchantRewards.Where(r => r.IsActive && r.PointCost > current && r.PointCost <= afterSale).ToList();
        }
    }

    private PosClaimState GetPosClaimState(Guid id) =>
        PosClaimStates.TryGetValue(id, out var s) ? s : PosClaimState.Idle;

    private void ClearPosClaimStates()
    {
        foreach (var cts in PosClaimCts.Values) cts.Cancel();
        PosClaimCts.Clear();
        PosClaimStates.Clear();
        PosIsClaiming = false;
    }

    private async Task ClaimRewardFromPos(LoyaltyReward reward)
    {
        if (selectedCustomerId == null || PosIsClaiming) return;
        if (PosClaimStates.TryGetValue(reward.Id, out var ex) && ex == PosClaimState.Pending) return;

        var cts = new CancellationTokenSource();
        PosClaimCts[reward.Id] = cts;
        PosIsClaiming = true;
        PosClaimStates[reward.Id] = PosClaimState.Pending;
        StateHasChanged();

        var response = await CustomerService.ClaimRewardAsync(new ClaimRewardRequest
        {
            CustomerId = selectedCustomerId.Value,
            RewardId = reward.Id,
            Notes = "Claimed via POS Terminal"
        });

        PosIsClaiming = false;

        if (response.IsSuccess)
        {
            PosClaimStates[reward.Id] = PosClaimState.Success;
            var loyaltyRes = await CustomerService.GetCustomerLoyaltyAsync(selectedCustomerId.Value);
            if (loyaltyRes.IsSuccess)
            {
                selectedCustomerLoyalty = loyaltyRes.Data;
                CalculateReachableRewards();
            }
            StateHasChanged();
            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                if (PosClaimStates.TryGetValue(reward.Id, out var s) && s == PosClaimState.Success)
                    PosClaimStates[reward.Id] = PosClaimState.Idle;
                await InvokeAsync(StateHasChanged);
            });
        }
        else
        {
            PosClaimStates[reward.Id] = PosClaimState.Idle;
            statusMessage = response.Message ?? "Claim failed. Please try again.";
            isError = true;
            StateHasChanged();
        }
    }

    private async Task LoadCustomers()
    {
        try
        {
            var filter = new PaginationFilter { PageNumber = 1, PageSize = 1000 };
            var response = await CustomerService.GetCustomersAsync(currentMerchantId, filter);
            if (response?.Data?.Data != null)
            {
                CustomerList = response.Data.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading customers: {ex.Message}");
        }
    }

    private async Task LoadBranches()
    {
        var response = await BranchService.GetAllBranchesAsync(new PaginationFilter { PageSize = 100 });
        if (response?.Data?.Data != null)
        {
            BranchList = response.Data.Data.ToList();
            if (!IsStaff && !selectedBranchId.HasValue && BranchList.Any())
            {
                // Admin/MerchantAdmin: auto-select first branch and load its inventory
                selectedBranchId = BranchList.First().Id;
            }
            // Staff: inventory already loaded directly in OnInitializedAsync — skip to avoid double call
            if (!IsStaff && selectedBranchId.HasValue)
            {
                await LoadInventoryForBranch();
            }
            StateHasChanged();
        }
    }

    private async Task LoadCategories()
    {
        var response = await CategoryService.GetCategoriesAsync(new PaginationFilter { PageSize = 100 });
        if (response?.Data?.Data != null)
        {
            CategoryList = response.Data.Data.ToList();
        }
    }

    private async Task LoadProducts(bool isSearching = false)
    {
        if (!isSearching) isLoading = true;
        this.isSearching = isSearching;
        try 
        {
            var filter = new PaginationFilter() 
            { 
                PageNumber = 1, 
                PageSize = 50,
                SearchTerm = SearchQuery,
                CategoryId = selectedCategoryId
            };
            var response = await ProductService.GetProductsAsync(filter);
            if (response?.Data?.Data != null)
            {
                ProductList = response.Data.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
            ProductList = new();
        }
        finally
        {
            isLoading = false;
            isSearching = false;
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            await LoadProducts(isSearching: true);
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task HandleCategoryChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (Guid.TryParse(value, out var guid))
            selectedCategoryId = guid;
        else
            selectedCategoryId = null;
        
        await LoadProducts();
    }

    private async Task HandleBranchChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (Guid.TryParse(value, out var guid))
        {
            selectedBranchId = guid;
            await LoadInventoryForBranch();
        }
        else
        {
            selectedBranchId = null;
            BranchInventory.Clear();
        }
        CartItems.Clear();
        statusMessage = "";
    }

    private async Task LoadInventoryForBranch()
    {
        if (selectedBranchId.HasValue)
        {
            var response = await InventoryService.GetBranchInventoryAsync(selectedBranchId.Value, new PaginationFilter { PageSize = 1000 });
            if (response.IsSuccess && response.Data?.Data != null)
            {
                BranchInventory = response.Data.Data.ToList();
            }
            else
            {
                BranchInventory.Clear();
            }
        }
    }

    private decimal Subtotal => CartItems.Sum(i => i.Price * i.Qty);
    private decimal Tax => Math.Round(Subtotal * 0.05m, 2);
    private decimal Total => Subtotal + Tax;

    private void AddToCart(ProductsResponseDto p, int stock)
    {
        statusMessage = "";
        isError = false;
        var existing = CartItems.FirstOrDefault(c => c.ProductId == p.Id);
        if (existing != null) 
        {
            if (existing.Qty < stock)
                existing.Qty++;
            else
            {
                statusMessage = $"Only {stock} items available.";
                isError = true;
            }
        }
        else 
        {
            if (stock > 0)
                CartItems.Add(new CartItem 
                { 
                    ProductId = p.Id, 
                    Name = p.Name, 
                    Icon = CategoryIconHelper.GetIcon(p.CategoryName), 
                    Price = p.Price,
                    MaxStock = stock
                });
        }
        CalculateReachableRewards();
    }

    private void ChangeQty(CartItem item, int delta)
    {
        statusMessage = "";
        isError = false;
        if (delta > 0 && item.Qty >= item.MaxStock)
        {
            statusMessage = $"Only {item.MaxStock} items available.";
            isError = true;
            return;
        }
        item.Qty += delta;
        if (item.Qty <= 0) CartItems.Remove(item);
        CalculateReachableRewards();
    }

    private void HandleQtyInputChange(CartItem item, ChangeEventArgs e)
    {
        statusMessage = "";
        isError = false;
        if (int.TryParse(e.Value?.ToString(), out var newQty))
        {
            if (newQty <= 0)
            {
                CartItems.Remove(item);
            }
            else if (newQty > item.MaxStock)
            {
                item.Qty = item.MaxStock;
                statusMessage = $"Maximum available quantity is {item.MaxStock}.";
                isError = true;
            }
            else
            {
                item.Qty = newQty;
            }
        }
        CalculateReachableRewards();
    }

    private void ClearCart() 
    {
        CartItems.Clear();
        statusMessage = "";
        reachableAfterSale.Clear();
        CalculateReachableRewards();
    }

    private async Task HandleCheckout()
    {
        if (isProcessing || !CartItems.Any()) return;

        isProcessing = true;
        statusMessage = "";
        isError = false;

        try
        {
            if (selectedBranchId == null || selectedBranchId == Guid.Empty)
            {
                statusMessage = "Please select a branch before checking out.";
                isError = true;
                return;
            }

            var request = new CreateOrderRequest
            {
                BranchId = selectedBranchId.Value,
                CustomerId = selectedCustomerId,
                ApplyLoyalty = applyLoyalty,
                Items = CartItems.Select(i => new CreateOrderItemRequest
                {
                    ProductId = i.ProductId,
                    Quantity = i.Qty
                }).ToList()
            };

            var earnedPoints = applyLoyalty ? CalculateEarnedPoints() : 0;
            var response = await SaleService.CreateOrderAsync(request);
            if (response != null && response.Message == "Order Created")
            {
                if (selectedCustomerId.HasValue && selectedCustomerId.Value != Guid.Empty)
                {
                    statusMessage = $"Order completed successfully! Earned {earnedPoints.ToString("N0")} points.";
                }
                else
                {
                    statusMessage = "Order completed successfully!";
                }
                isError = false;
                CartItems.Clear();
                selectedCustomerLoyalty = null;
                reachableNow.Clear();
                reachableAfterSale.Clear();
                ClearPosClaimStates();
                if (selectedCustomerId.HasValue)
                {
                    // Refresh loyalty data for selected customer
                    var loyaltyRes = await CustomerService.GetCustomerLoyaltyAsync(selectedCustomerId.Value);
                    if (loyaltyRes.IsSuccess)
                    {
                        selectedCustomerLoyalty = loyaltyRes.Data;
                        CalculateReachableRewards();
                    }
                }
            }
            else
            {
                statusMessage = response?.Message ?? "Failed to create order";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            isError = true;
        }
        finally
        {
            isProcessing = false;
        }
    }


